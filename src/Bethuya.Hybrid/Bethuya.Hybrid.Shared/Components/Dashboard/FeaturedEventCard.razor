@if (Event is not null)
{
    <div class="featured-card" data-test="featured-event-card">
        <div class="featured-photo" role="img" aria-label="@Event.Title event photo">
            <div class="featured-photo-overlay" aria-hidden="true"></div>
        </div>
        <div class="featured-body">
            <h2 class="featured-title">@Event.Title</h2>
            <p class="featured-desc">@(Event.Description ?? "")</p>

            <div class="featured-meta">
                <div class="meta-item">
                    <span class="meta-label">Location</span>
                    <span class="meta-value">@(Event.Location ?? "TBD")</span>
                </div>
                <div class="meta-divider" aria-hidden="true"></div>
                <div class="meta-item">
                    <span class="meta-label">Date</span>
                    <span class="meta-value">
                        @Event.StartDate.ToString("MMM d, yyyy")@(Event.StartDate != Event.EndDate ? $" – {Event.EndDate:MMM d, yyyy}" : "")
                    </span>
                </div>
            </div>
        </div>
        <div class="featured-actions">
            <button class="feat-btn feat-btn--outline" type="button" @onclick="@(() => OnPanelClick.InvokeAsync())">
                Panel
                <LucideIcon Name="bot" Size="14" />
            </button>
            <button class="feat-btn feat-btn--outline" type="button" @onclick="@(() => OnCurationClick.InvokeAsync())">
                Curation
                <LucideIcon Name="settings" Size="14" />
            </button>
            <button class="feat-btn feat-btn--gold" type="button" @onclick="@(() => OnCreateClick.InvokeAsync())"
                    data-test="create-event-btn">
                Create New Event
                <LucideIcon Name="plus" Size="14" />
            </button>
        </div>
    </div>
}
else
{
    <div class="featured-card featured-card--empty" data-test="featured-event-card">
        <div class="empty-content">
            <p class="empty-text">No upcoming events.</p>
            <button class="feat-btn feat-btn--gold" type="button" @onclick="@(() => OnCreateClick.InvokeAsync())"
                    data-test="create-event-btn">
                Create New Event
                <LucideIcon Name="plus" Size="14" />
            </button>
        </div>
    </div>
}

@code {
    [Parameter] public EventViewModel? Event { get; set; }
    [Parameter] public EventCallback OnPanelClick { get; set; }
    [Parameter] public EventCallback OnCurationClick { get; set; }
    [Parameter] public EventCallback OnCreateClick { get; set; }
}
