
@using Bethuya.Hybrid.Shared.Auth
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject NavigationManager Navigation

<nav class="sidebar-nav" aria-label="Main navigation">
    <div class="brand-row">
        <a class="brand-link" href="" aria-label="Hackerspace Mumbai - Dashboard">
            <svg class="brand-logo" width="36" height="36" viewBox="0 0 36 36" aria-hidden="true" focusable="false">
                <polygon points="18,2 33,10 33,26 18,34 3,26 3,10" fill="none" stroke="currentColor" stroke-width="1.5" />
                <path d="M11 22 L11 16 L15 12 L18 10 L21 12 L25 16 L25 22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round" />
                <rect x="15" y="17" width="6" height="5" fill="none" stroke="currentColor" stroke-width="1.5" />
            </svg>
            <div class="brand-text">
                <span class="brand-name">Hackerspace</span>
                <span class="brand-sub">Mumbai</span>
            </div>
        </a>
    </div>

    <input type="checkbox" id="nav-toggle" title="Toggle navigation menu" class="navbar-toggler" aria-controls="nav-links" />
    <label for="nav-toggle" class="navbar-toggler-label" aria-hidden="true"></label>

    <div id="nav-links" class="nav-links" onclick="document.getElementById('nav-toggle').checked = false">
        <div class="nav-section">
            <div class="nav-item">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <svg class="nav-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/>
                    </svg>
                    Dashboard
                </NavLink>
            </div>
            <div class="nav-item">
                <NavLink class="nav-link" href="events">
                    <svg class="nav-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
                    </svg>
                    Events
                </NavLink>
            </div>
        </div>

        @* Privileged links: These are landing pages that guide users to select an event first.
           Routes like /agents/{eventId} require an event context and should only be accessed from
           within an event detail page. These nav items help users discover the features. *@
        <AuthorizeView Roles="@OrganizerToolsRoles" Context="privilegedContext">
            <div class="nav-section">
                <div class="nav-section-label">Organizer Tools</div>
                @if (_currentEventId is Guid currentEventId)
                {
                    <AuthorizeView Roles="@AgentWorkflowRoles">
                        <div class="nav-item">
                            <NavLink class="nav-link" href="@($"agents/{currentEventId}")" Match="NavLinkMatch.Prefix" data-test="nav-agent-workflows-link">
                                <svg class="nav-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M12 8V4H8" /><rect x="4" y="8" width="16" height="12" rx="2" /><path d="M8 12h8" /><path d="M8 16h5" />
                                </svg>
                                Agent Workflows
                            </NavLink>
                        </div>
                    </AuthorizeView>

                    <AuthorizeView Roles="@CurationRoles">
                        <div class="nav-item">
                            <NavLink class="nav-link" href="@($"curation/{currentEventId}")" Match="NavLinkMatch.Prefix" data-test="nav-curation-link">
                                <svg class="nav-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                    <path d="M3 7h18" /><path d="M7 12h10" /><path d="M10 17h4" />
                                </svg>
                                Curation
                            </NavLink>
                        </div>
                    </AuthorizeView>
                }
                else
                {
                    <div class="nav-item">
                        <p class="text-xs text-muted-foreground p-3 italic">
                            ℹ️ Select an event to access agent workflows and curation. Agent features are accessed from event detail pages.
                        </p>
                    </div>
                }
            </div>
        </AuthorizeView>

        <div class="nav-section nav-section--bottom">
            <div class="nav-item">
                <NavLink class="nav-link" href="profile" Match="NavLinkMatch.Prefix" data-test="nav-profile-link">
                    <svg class="nav-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                    </svg>
                    Profile
                </NavLink>
            </div>
        </div>
    </div>
</nav>

@code {
    private const string OrganizerToolsRoles = $"{BethuyaRoles.Admin},{BethuyaRoles.Organizer},{BethuyaRoles.Curator}";
    private const string AgentWorkflowRoles = $"{BethuyaRoles.Admin},{BethuyaRoles.Organizer}";
    private const string CurationRoles = $"{BethuyaRoles.Admin},{BethuyaRoles.Curator}";

    private Guid? _currentEventId;

    protected override void OnInitialized()
    {
        _currentEventId = TryGetEventIdFromUri();
        Navigation.LocationChanged += HandleLocationChanged;
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _currentEventId = TryGetEventIdFromUri();
        InvokeAsync(StateHasChanged);
    }

    private Guid? TryGetEventIdFromUri()
    {
        var path = Navigation.ToBaseRelativePath(Navigation.Uri).Trim('/');
        if (string.IsNullOrWhiteSpace(path))
        {
            return null;
        }

        var segments = path.Split('/', StringSplitOptions.RemoveEmptyEntries);

        if (segments.Length >= 2 &&
            string.Equals(segments[0], "events", StringComparison.OrdinalIgnoreCase) &&
            Guid.TryParse(segments[1], out var eventIdFromEventRoute))
        {
            return eventIdFromEventRoute;
        }

        if (segments.Length >= 2 &&
            (string.Equals(segments[0], "agents", StringComparison.OrdinalIgnoreCase) ||
             string.Equals(segments[0], "curation", StringComparison.OrdinalIgnoreCase)) &&
            Guid.TryParse(segments[1], out var eventIdFromToolRoute))
        {
            return eventIdFromToolRoute;
        }

        return null;
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= HandleLocationChanged;
    }
}
