@page "/registration/mandatory"
@rendermode InteractiveServer
@layout OnboardingLayout
@attribute [Authorize]
@using System.ComponentModel.DataAnnotations
@using Bethuya.Hybrid.Shared.Services
@using BlazorBlueprint.Components
@using BlazorBlueprint.Primitives
@inject IProfileApi ProfileApi
@inject NavigationManager Navigation

<PageTitle>Complete Your Profile — Bethuya</PageTitle>

<section class="profile-page" aria-label="Complete your profile">
    <div class="profile-container">

        <header class="profile-header">
            <p class="profile-step">Step 1 of 3 · Required details</p>
            <h1 class="profile-title">Let's set up your Bethuya profile</h1>
            <p class="profile-subtitle">
                We just need the essentials before you enter the community dashboard.
                These details help organizers run events safely and communicate clearly with you.
            </p>
            <div class="profile-progress" aria-hidden="true">
                <span class="profile-progress__dot profile-progress__dot--active"></span>
                <span class="profile-progress__dot"></span>
                <span class="profile-progress__dot"></span>
            </div>
        </header>

        <div class="profile-layout">
            <section class="profile-main">
                <EditForm Model="@_model" OnValidSubmit="@HandleValidSubmit" FormName="mandatory-profile">
                    <DataAnnotationsValidator />

                    <fieldset disabled="@_isLoading">
                        <BbCard Class="profile-form-card">
                            <BbCardHeader>
                                <BbCardTitle>Let’s set up your Bethuya profile</BbCardTitle>
                                <BbCardDescription>
                                    Complete this once so Bethuya can personalize registration, reminders, and venue logistics.
                                </BbCardDescription>
                            </BbCardHeader>
                            <BbCardContent Class="profile-form-card__content">
                                @if (_isLoading)
                                {
                                    <div data-test="mandatory-profile-loading">
                                        <BbAlert Variant="AlertVariant.Info">
                                            <BbAlertDescription>Loading your saved profile details…</BbAlertDescription>
                                        </BbAlert>
                                    </div>
                                }

                                <BbFormSection Title="Personal Details" Description="The basics we need to set up your profile.">

                                <div class="space-y-4">
                                    <div class="name-row">
                                        <BbFormFieldInput @bind-Value="_model.FirstName"
                                                          Label="First Name"
                                                          Placeholder="Enter your first name"
                                                          Required="true" />
                                        <BbFormFieldInput @bind-Value="_model.LastName"
                                                          Label="Last Name"
                                                          Placeholder="Enter your last name"
                                                          Required="true" />
                                    </div>

                                    <BbFormFieldInput @bind-Value="_model.Email"
                                                      Label="Email Address"
                                                      Placeholder="you@example.com"
                                                      Required="true" />

                                    <BbFormFieldInput @bind-Value="_model.MobileNumber"
                                                      Label="Mobile Number"
                                                      Placeholder="+91 98765 43210" />
                                </div>
                            </BbFormSection>

                            <BbFormSection Title="Professional Context" Description="This helps us tailor event recommendations">
                                <div class="space-y-4">
                                    <BbFormFieldRadioGroup @bind-Value="_model.OccupationStatus"
                                                           Label="Current employment status"
                                                           InputClass="employment-radio-group">
                                        <BbRadioGroupItem Value="@("Student")" Label="Student" />
                                        <BbRadioGroupItem Value="@("Working Professional")" Label="Working Professional" />
                                        <BbRadioGroupItem Value="@("Independent / Freelancer")" Label="Independent / Freelancer" />
                                    </BbFormFieldRadioGroup>

                                    @if (IsCompanyOrOrganizationRequired)
                                    {
                                        <BbFormFieldInput @bind-Value="_model.CompanyName"
                                                          Label="Company / Organization"
                                                          Placeholder="Start typing your company name"
                                                          Required="true" />
                                        <p class="profile-actions-hint">We use this to maintain a balanced mix across organizations</p>
                                    }

                                    @if (IsStudent)
                                    {
                                        <BbFormFieldInput @bind-Value="_model.EducationInstitute"
                                                          Label="College / University"
                                                          Placeholder="Start typing your college name"
                                                          Required="true" />
                                        <p class="profile-actions-hint">We use this to ensure balanced representation across colleges</p>
                                    }
                                </div>
                            </BbFormSection>

                            <BbFormSection Title="Location" Description="Minimal location details help us match relevant events.">

                                <div class="space-y-4">
                                    <BbFormFieldInput @bind-Value="_model.City"
                                                      Label="City"
                                                      Placeholder="Mumbai" />

                                    <BbFormFieldInput @bind-Value="_model.Country"
                                                      Label="Country"
                                                      Placeholder="India" />
                                </div>

                            </BbFormSection>

                                @if (_loadErrorMessage is not null)
                                {
                                    <div data-test="profile-load-error">
                                        <BbAlert Variant="AlertVariant.Danger">
                                            <BbAlertDescription>@_loadErrorMessage</BbAlertDescription>
                                        </BbAlert>
                                    </div>
                                }

                                @if (_errorMessage is not null)
                                {
                                    <div data-test="profile-error">
                                        <BbAlert Variant="AlertVariant.Danger">
                                            <BbAlertDescription>@_errorMessage</BbAlertDescription>
                                        </BbAlert>
                                    </div>
                                }
                            </BbCardContent>
                        </BbCard>
                    </fieldset>

                    <div class="profile-actions">
                        <div class="profile-actions-copy">
                            <p class="profile-actions-title">Next step: verify your GitHub or LinkedIn profile</p>
                            <p class="profile-actions-hint">We'll save these details first, then continue to social verification.</p>
                        </div>
                        <button type="submit" class="profile-primary-button" disabled="@(_isLoading || _isSaving)" data-test="save-profile-btn">
                            @if (_isSaving)
                            {
                                <span>Saving…</span>
                            }
                            else
                            {
                                <span>Save &amp; Continue</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </section>

            <aside class="profile-sidebar" aria-label="Why we ask for this information">
                <BbCard Class="profile-info-card">
                    <BbCardHeader>
                        <BbCardTitle>Why we ask</BbCardTitle>
                    </BbCardHeader>
                    <BbCardContent>
                        <ul class="profile-bullets">
                            <li>To help organizers reach you.</li>
                            <li>To recommend relevant events.</li>
                        </ul>
                        <p class="profile-actions-hint">Next: &rarr; Verify GitHub or LinkedIn</p>
                    </BbCardContent>
                </BbCard>
            </aside>
        </div>

    </div>
</section>

@code {
    private readonly MandatoryProfileModel _model = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _loadErrorMessage;
    private string? _errorMessage;
    private static bool IsDevelopmentBypassEnabled =>
        string.Equals(Environment.GetEnvironmentVariable("Onboarding__BypassSocialConnections"), "true", StringComparison.OrdinalIgnoreCase);

    private bool IsCompanyOrOrganizationRequired => IsCompanyRequiredOccupation(_model.OccupationStatus);
    private bool IsStudent => string.Equals(_model.OccupationStatus, "Student", StringComparison.Ordinal);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var profile = await ProfileApi.GetMandatoryProfileAsync();
            ApplySavedProfile(profile);
        }
        catch (Exception)
        {
            _loadErrorMessage = "We couldn't load your saved profile details. Review the form before saving.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        _isSaving = true;
        _errorMessage = null;

        try
        {
            await ProfileApi.SaveMandatoryProfileAsync(new SaveMandatoryProfileDto(
                _model.FirstName!,
                _model.LastName!,
                _model.Email!,
                _model.MobileNumber,
                _model.GovernmentPhotoIdType,
                _model.GovernmentIdLastFour,
                _model.OccupationStatus,
                IsCompanyOrOrganizationRequired ? _model.CompanyName : null,
                IsStudent ? _model.EducationInstitute : null,
                _model.City,
                _model.State,
                _model.PostalCode,
                _model.Country));

            Navigation.NavigateTo(IsDevelopmentBypassEnabled ? "/registration/aide" : "/registration/social");
        }
        catch (Exception)
        {
            _errorMessage = "Failed to save your profile. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ApplySavedProfile(MandatoryProfileDto? profile)
    {
        if (profile is null)
        {
            return;
        }

        _model.FirstName = profile.FirstName;
        _model.LastName = profile.LastName;
        _model.Email = profile.Email;
        _model.MobileNumber = profile.MobileNumber;
        _model.GovernmentPhotoIdType = profile.GovernmentPhotoIdType;
        _model.GovernmentIdLastFour = profile.GovernmentIdLastFour;
        _model.OccupationStatus = NormalizeOccupationStatus(profile.OccupationStatus);
        _model.CompanyName = profile.CompanyName;
        _model.EducationInstitute = profile.EducationInstitute;
        _model.City = profile.City;
        _model.State = profile.State;
        _model.PostalCode = profile.PostalCode;
        _model.Country = profile.Country;
    }

    private static bool IsCompanyRequiredOccupation(string? occupationStatus)
        => string.Equals(occupationStatus, "Working Professional", StringComparison.Ordinal)
            || string.Equals(occupationStatus, "Independent / Freelancer", StringComparison.Ordinal)
            || string.Equals(occupationStatus, "Employee", StringComparison.Ordinal)
            || string.Equals(occupationStatus, "Self-employed", StringComparison.Ordinal)
            || string.Equals(occupationStatus, "Founder", StringComparison.Ordinal)
            || string.Equals(occupationStatus, "Freelancer", StringComparison.Ordinal)
            || string.Equals(occupationStatus, "Full time employed", StringComparison.Ordinal)
            || string.Equals(occupationStatus, "Full-time employed", StringComparison.Ordinal);

    private static string? NormalizeOccupationStatus(string? occupationStatus)
        => occupationStatus switch
        {
            "Employee" or "Full time employed" or "Full-time employed" => "Working Professional",
            "Self-employed" or "Founder" or "Freelancer" => "Independent / Freelancer",
            _ => occupationStatus
        };

    private sealed class MandatoryProfileModel : IValidatableObject
    {
        [Required(ErrorMessage = "First name is required.")]
        [MaxLength(100)]
        public string? FirstName { get; set; }

        [Required(ErrorMessage = "Last name is required.")]
        [MaxLength(100)]
        public string? LastName { get; set; }

        [Required(ErrorMessage = "Email address is required.")]
        [EmailAddress(ErrorMessage = "Enter a valid email address.")]
        [MaxLength(200)]
        public string? Email { get; set; }

        [MaxLength(30)]
        public string? MobileNumber { get; set; }

        [MaxLength(100)]
        public string? GovernmentPhotoIdType { get; set; }

        [RegularExpression(@"^\d{4}$", ErrorMessage = "Enter exactly 4 digits for the ID.")]
        public string? GovernmentIdLastFour { get; set; }

        [Required(ErrorMessage = "Current employment status is required.")]
        [MaxLength(200)]
        public string? OccupationStatus { get; set; }

        [MaxLength(200)]
        public string? CompanyName { get; set; }

        [MaxLength(200)]
        public string? EducationInstitute { get; set; }

        [MaxLength(100)]
        public string? City { get; set; }

        [MaxLength(100)]
        public string? State { get; set; }

        [MaxLength(20)]
        public string? PostalCode { get; set; }

        [MaxLength(100)]
        public string? Country { get; set; }

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (IsCompanyRequiredOccupation(OccupationStatus) && string.IsNullOrWhiteSpace(CompanyName))
            {
                yield return new ValidationResult(
                    "Company / Organization is required for working professionals and independent attendees.",
                    [nameof(CompanyName)]);
            }

            if (string.Equals(OccupationStatus, "Student", StringComparison.Ordinal) && string.IsNullOrWhiteSpace(EducationInstitute))
            {
                yield return new ValidationResult(
                    "College / University is required when employment status is Student.",
                    [nameof(EducationInstitute)]);
            }
        }
    }
}
