@page "/registration/social"
@rendermode InteractiveServer
@layout OnboardingLayout
@attribute [Authorize]
@using Microsoft.AspNetCore.Components
@using Bethuya.Hybrid.Shared.Services
@using BlazorBlueprint.Components
@inject IProfileApi ProfileApi
@inject NavigationManager Navigation

<PageTitle>Verify Social Profiles — Bethuya</PageTitle>

<section class="profile-page" aria-label="Verify your social profiles">
    <div class="profile-container">

        <header class="profile-header">
            <p class="profile-step">Step 2 of 3 · Verified social accounts</p>
            <h1 class="profile-title">Connect the accounts you actually use</h1>
            <p class="profile-subtitle">
                Sign in to GitHub and LinkedIn so Bethuya stores verified identities instead of typed handles.
                This step is separate on purpose, so your saved profile details stay intact through the OAuth redirect.
                Connect both if you can because having both verified accounts improves your chances for selection.
            </p>
            <div class="profile-progress" aria-hidden="true">
                <span class="profile-progress__dot"></span>
                <span class="profile-progress__dot profile-progress__dot--active"></span>
                <span class="profile-progress__dot"></span>
            </div>
        </header>

        <div class="profile-layout">
            <section class="profile-main">
                <BbCard Class="profile-form-card">
                    <BbCardHeader>
                        <BbCardTitle>Verified social profiles</BbCardTitle>
                        <BbCardDescription>
                            @GetCompletionInstruction()
                        </BbCardDescription>
                    </BbCardHeader>
                    <BbCardContent Class="profile-form-card__content">
                        <div class="social-connection-grid social-connection-grid--stacked" data-test="social-connection-stack">
                            <div class="social-connection-stack-intro" data-test="social-stack-cue">
                                <p class="social-connection-stack-intro__eyebrow">Two verification cards</p>
                                <p class="social-connection-stack-intro__text">LinkedIn comes first. GitHub verification continues directly below in this same stack.</p>
                            </div>

                            <BbCard Class="social-connection-card">
                                @{
                                    var linkedInError = GetProviderSocialErrorMessage("linkedin");
                                }
                                <BbCardHeader>
                                    <BbCardTitle>LinkedIn</BbCardTitle>
                                    <BbCardDescription>@GetLinkedInCardDescription()</BbCardDescription>
                                </BbCardHeader>
                                <BbCardContent Class="social-connection-card__content">
                                    <div class="social-connection-details">
                                        @if (_isLoading)
                                        {
                                            <p class="social-connection-status social-connection-status--pending" data-test="linkedin-loading-status">
                                                Loading your saved LinkedIn status…
                                            </p>
                                        }
                                        else if (HasLoadError)
                                        {
                                            <p class="social-connection-status social-connection-status--pending" data-test="linkedin-load-error-status">
                                                We couldn&apos;t load your saved LinkedIn status.
                                            </p>
                                        }
                                        else if (IsLinkedInConnected)
                                        {
                                            <p class="social-connection-status" data-test="linkedin-connected-status">
                                                Connected as <strong>@_model.LinkedInMemberId</strong>
                                            </p>
                                        }
                                        else
                                        {
                                            <p class="social-connection-status social-connection-status--pending" data-test="linkedin-pending-status">
                                                Not connected yet.
                                            </p>
                                        }
                                    </div>

                                    <div class="social-connection-linkedin-field" data-test="linkedin-profile-url-field">
                                        <BbFormFieldInput TValue="string"
                                                          @bind-Value="_model.LinkedInProfileUrl"
                                                          Label="Public LinkedIn profile URL"
                                                          HelperText="@GetLinkedInUrlHelperText()"
                                                          Placeholder="https://www.linkedin.com/in/your-handle"
                                                          Type="InputType.Url"
                                                          Disabled="@(IsLinkedInConnected || AreSocialControlsDisabled)" />
                                    </div>

                                    <div class="social-connection-action" data-test="connect-linkedin-btn">
                                        <button type="button" class="social-connection-button" disabled="@(!CanStartLinkedInConnect)" @onclick="@(() => BeginSocialConnect("linkedin"))">
                                            @(IsLinkedInConnected ? "Reconnect LinkedIn" : "Connect LinkedIn")
                                        </button>
                                    </div>

                                    <div class="social-connection-feedback">
                                        @if (linkedInError is not null)
                                        {
                                            <div class="social-connection-error" data-test="social-connect-error">
                                                <p class="social-connection-error__eyebrow">Social connection needs attention</p>
                                                <p class="social-connection-error__provider">LinkedIn needs attention</p>
                                                <p class="social-connection-error__message">@linkedInError</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="social-connection-feedback__placeholder" aria-hidden="true">
                                                LinkedIn connection feedback appears here when needed.
                                            </p>
                                        }
                                    </div>
                                </BbCardContent>
                            </BbCard>

                            <BbCard Class="social-connection-card">
                                @{
                                    var gitHubError = GetProviderSocialErrorMessage("github");
                                }
                                <BbCardHeader>
                                    <BbCardTitle>GitHub</BbCardTitle>
                                    <BbCardDescription>@GetGitHubCardDescription()</BbCardDescription>
                                </BbCardHeader>
                                <BbCardContent Class="social-connection-card__content">
                                    <div class="social-connection-details">
                                        @if (_isLoading)
                                        {
                                            <p class="social-connection-status social-connection-status--pending" data-test="github-loading-status">
                                                Loading your saved GitHub status…
                                            </p>
                                        }
                                        else if (HasLoadError)
                                        {
                                            <p class="social-connection-status social-connection-status--pending" data-test="github-load-error-status">
                                                We couldn&apos;t load your saved GitHub status.
                                            </p>
                                        }
                                        else if (IsGitHubConnected)
                                        {
                                            <p class="social-connection-status" data-test="github-connected-status">
                                                Connected as <strong>@_model.GitHubLogin</strong>
                                            </p>
                                        }
                                        else
                                        {
                                            <p class="social-connection-status social-connection-status--pending" data-test="github-pending-status">
                                                Not connected yet.
                                            </p>
                                        }

                                        <p class="@GetGitHubMetaClass()" data-test="github-meta">
                                            @GetGitHubMetaText()
                                        </p>

                                        <p class="social-connection-support" data-test="github-support">
                                            @GetGitHubSupportText()
                                        </p>
                                    </div>

                                    <div class="social-connection-action" data-test="connect-github-btn">
                                        <button type="button" class="social-connection-button" disabled="@AreSocialControlsDisabled" @onclick="@(() => BeginSocialConnect("github"))">
                                            @(IsGitHubConnected ? "Reconnect GitHub" : "Connect GitHub")
                                        </button>
                                    </div>

                                    <div class="social-connection-feedback">
                                        @if (gitHubError is not null)
                                        {
                                            <div class="social-connection-error" data-test="social-connect-error">
                                                <p class="social-connection-error__eyebrow">Social connection needs attention</p>
                                                <p class="social-connection-error__provider">GitHub needs attention</p>
                                                <p class="social-connection-error__message">@gitHubError</p>
                                            </div>
                                        }
                                        else
                                        {
                                            <p class="social-connection-feedback__placeholder" aria-hidden="true">
                                                GitHub connection feedback appears here when needed.
                                            </p>
                                        }
                                    </div>
                                </BbCardContent>
                            </BbCard>
                        </div>

                        @if (HasGeneralSocialError)
                        {
                            <div class="social-connection-error" data-test="social-connect-error">
                                <p class="social-connection-error__eyebrow">Social connection needs attention</p>
                                <p class="social-connection-error__message">@_socialErrorMessage</p>
                            </div>
                        }

                        @if (HasLoadError)
                        {
                            <div data-test="social-profile-error">
                                <BbAlert Variant="AlertVariant.Danger">
                                    <BbAlertDescription>@_loadErrorMessage</BbAlertDescription>
                                </BbAlert>
                            </div>
                        }

                        @if (_actionErrorMessage is not null)
                        {
                            <div data-test="social-profile-error">
                                <BbAlert Variant="AlertVariant.Danger">
                                    <BbAlertDescription>@_actionErrorMessage</BbAlertDescription>
                                </BbAlert>
                            </div>
                        }
                    </BbCardContent>
                </BbCard>

                <div class="profile-actions">
                    <div class="profile-actions-copy">
                        <p class="profile-actions-title">Verified before you continue.</p>
                        <p class="profile-actions-hint">@GetActionHint()</p>
                    </div>
                    <button type="button" class="profile-primary-button" disabled="@(_isSaving || _isLoading || !CanContinue)" @onclick="HandleContinue" data-test="save-social-btn">
                        @if (_isSaving)
                        {
                            <span>Saving…</span>
                        }
                        else
                        {
                            <span>Save &amp; Continue</span>
                        }
                    </button>
                </div>
            </section>

            <aside class="profile-sidebar" aria-label="How Bethuya uses verified social accounts">
                <BbCard Class="profile-info-card">
                    <BbCardHeader>
                        <BbCardTitle>Why this step exists</BbCardTitle>
                        <BbCardDescription>We verify once instead of asking you to type identities we cannot trust.</BbCardDescription>
                    </BbCardHeader>
                    <BbCardContent>
                        <ol class="profile-checklist">
                            <li>OAuth confirms the account is really yours.</li>
                            <li>Your saved mandatory profile is already safe before any redirect happens.</li>
                            <li>Returning from GitHub or LinkedIn drops you right back into this step.</li>
                            <li>Both verified accounts strengthen your selection profile, even when only one is required.</li>
                        </ol>
                    </BbCardContent>
                </BbCard>

                <BbCard Class="profile-info-card">
                    <BbCardHeader>
                        <BbCardTitle>What happens next</BbCardTitle>
                    </BbCardHeader>
                    <BbCardContent>
                        <ul class="profile-bullets">
                            <li>Save the account required for your current status.</li>
                            <li>Connect both whenever possible to improve your chances for selection.</li>
                            <li>Optionally add accessibility and inclusion context.</li>
                            <li>Enter Bethuya with your profile fully set up.</li>
                        </ul>
                    </BbCardContent>
                </BbCard>
            </aside>
        </div>

    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "linkedinMemberId")]
    public string? LinkedInMemberIdQuery { get; set; }

    [SupplyParameterFromQuery(Name = "linkedinProfileUrl")]
    public string? LinkedInProfileUrlQuery { get; set; }

    [SupplyParameterFromQuery(Name = "githubLogin")]
    public string? GitHubLoginQuery { get; set; }

    [SupplyParameterFromQuery(Name = "githubProfileUrl")]
    public string? GitHubProfileUrlQuery { get; set; }

    [SupplyParameterFromQuery(Name = "socialError")]
    public string? SocialErrorQuery { get; set; }

    [SupplyParameterFromQuery(Name = "socialProvider")]
    public string? SocialProviderQuery { get; set; }

    private readonly SocialProfileModel _model = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _loadErrorMessage;
    private string? _actionErrorMessage;
    private string? _socialErrorMessage;

    private bool IsLinkedInConnected => !string.IsNullOrWhiteSpace(_model.LinkedInMemberId);
    private bool IsGitHubConnected => !string.IsNullOrWhiteSpace(_model.GitHubLogin) && !string.IsNullOrWhiteSpace(_model.GitHubProfileUrl);
    private bool IsLinkedInRequired => _model.IsLinkedInRequired;
    private bool IsGitHubRequired => _model.IsGitHubRequired;
    private bool HasLoadError => _loadErrorMessage is not null;
    private bool AreSocialControlsDisabled => _isLoading || _isSaving || HasLoadError;
    private bool HasLinkedInProfileUrlForConnect => !string.IsNullOrWhiteSpace(GetNormalizedLinkedInProfileUrl());
    private bool CanStartLinkedInConnect => !AreSocialControlsDisabled && (IsLinkedInConnected || HasLinkedInProfileUrlForConnect);
    private bool CanContinue => !AreSocialControlsDisabled && (!IsLinkedInRequired || IsLinkedInConnected) && (!IsGitHubRequired || IsGitHubConnected);

    protected override void OnParametersSet()
    {
        ApplyQueryValues();
        _socialErrorMessage = ResolveSocialErrorMessage();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var status = await ProfileApi.GetCompletionStatusAsync();
            if (!status.IsProfileComplete)
            {
                Navigation.NavigateTo("/registration/mandatory", replace: true);
                return;
            }

            var socialProfile = await ProfileApi.GetSocialProfileAsync();
            _model.OccupationStatus = socialProfile.OccupationStatus;
            _model.IsLinkedInRequired = socialProfile.IsLinkedInRequired;
            _model.IsGitHubRequired = socialProfile.IsGitHubRequired;
            _model.LinkedInMemberId = socialProfile.LinkedInMemberId;
            _model.LinkedInProfileUrl = socialProfile.LinkedInProfileUrl;
            _model.GitHubLogin = socialProfile.GitHubLogin;
            _model.GitHubProfileUrl = socialProfile.GitHubProfileUrl;

            ApplyQueryValues();
        }
        catch (Exception)
        {
            _loadErrorMessage = "We couldn't load this onboarding step. Refresh the page before continuing.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleContinue()
    {
        if (!CanContinue)
        {
            _actionErrorMessage = GetRequiredConnectionError();
            return;
        }

        _isSaving = true;
        _actionErrorMessage = null;

        try
        {
            var linkedInProfileUrl = GetNormalizedLinkedInProfileUrl();

            await ProfileApi.SaveSocialProfileAsync(new SaveSocialProfileDto(
                _model.LinkedInMemberId,
                linkedInProfileUrl,
                _model.GitHubLogin,
                _model.GitHubProfileUrl));

            Navigation.NavigateTo("/registration/aide");
        }
        catch (Exception)
        {
            _actionErrorMessage = "Failed to save your verified social profiles. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void BeginSocialConnect(string provider)
    {
        if (string.Equals(provider, "linkedin", StringComparison.Ordinal) && !CanStartLinkedInConnect)
        {
            _actionErrorMessage = "Add your public LinkedIn profile URL before connecting LinkedIn.";
            return;
        }

        _actionErrorMessage = null;
        Navigation.NavigateTo($"/authentication/social/{provider}/start?returnUrl={Uri.EscapeDataString(BuildSocialReturnUrl())}", forceLoad: true);
    }

    private void ApplyQueryValues()
    {
        if (!string.IsNullOrWhiteSpace(LinkedInMemberIdQuery))
        {
            _model.LinkedInMemberId = LinkedInMemberIdQuery;
        }

        if (!string.IsNullOrWhiteSpace(LinkedInProfileUrlQuery))
        {
            _model.LinkedInProfileUrl = LinkedInProfileUrlQuery;
        }

        if (!string.IsNullOrWhiteSpace(GitHubLoginQuery))
        {
            _model.GitHubLogin = GitHubLoginQuery;
        }

        if (!string.IsNullOrWhiteSpace(GitHubProfileUrlQuery))
        {
            _model.GitHubProfileUrl = GitHubProfileUrlQuery;
        }
    }

    private string GetGitHubMetaClass()
        => _isLoading || HasLoadError
            ? "social-connection-meta"
            : string.IsNullOrWhiteSpace(_model.GitHubProfileUrl)
            ? "social-connection-meta social-connection-meta--placeholder"
            : "social-connection-meta";

    private string GetGitHubMetaText()
        => _isLoading
            ? "Loading saved GitHub profile details…"
            : HasLoadError
                ? "Refresh this page to reload your saved GitHub profile details."
                : string.IsNullOrWhiteSpace(_model.GitHubProfileUrl)
            ? "Verified GitHub profile details appear here after you connect."
            : _model.GitHubProfileUrl!;

    private string GetGitHubSupportText()
        => _isLoading
            ? "We will restore the verified GitHub profile URL for this card as soon as your saved state finishes loading."
            : HasLoadError
                ? "Reload this step before reconnecting so Bethuya can confirm whether GitHub was already saved."
                : IsGitHubConnected
                    ? "GitHub already supplied the verified profile URL Bethuya will keep on this step."
                    : "GitHub supplies the verified profile URL for you, so this card stays simpler even though the proof still matters.";

    private string GetLinkedInUrlHelperText()
        => _isLoading
            ? "Loading your saved LinkedIn state…"
            : HasLoadError
                ? "Refresh this page before editing the LinkedIn URL."
                : IsLinkedInConnected
                    ? "Locked after LinkedIn verification on this step."
                    : HasLinkedInProfileUrlForConnect
                        ? "Enter the exact public LinkedIn profile URL carefully before you connect. Bethuya locks this field after LinkedIn verification on this step."
                        : "Add your public LinkedIn profile URL to enable LinkedIn connect. Bethuya locks this field after LinkedIn verification on this step.";

    private bool HasGeneralSocialError => _socialErrorMessage is not null && GetNormalizedSocialProvider() is null;

    private string BuildSocialReturnUrl()
    {
        Dictionary<string, string?> query = [];
        var linkedInProfileUrl = GetNormalizedLinkedInProfileUrl();

        if (!string.IsNullOrWhiteSpace(_model.LinkedInMemberId))
        {
            query["linkedinMemberId"] = _model.LinkedInMemberId;
        }

        if (!string.IsNullOrWhiteSpace(linkedInProfileUrl))
        {
            query["linkedinProfileUrl"] = linkedInProfileUrl;
        }

        if (!string.IsNullOrWhiteSpace(_model.GitHubLogin))
        {
            query["githubLogin"] = _model.GitHubLogin;
        }

        if (!string.IsNullOrWhiteSpace(_model.GitHubProfileUrl))
        {
            query["githubProfileUrl"] = _model.GitHubProfileUrl;
        }

        return query.Count == 0
            ? "/registration/social"
            : $"/registration/social?{string.Join("&", query.Select(static pair => $"{pair.Key}={Uri.EscapeDataString(pair.Value ?? string.Empty)}"))}";
    }

    private string GetCompletionInstruction()
        => (IsGitHubRequired, IsLinkedInRequired) switch
        {
            (true, false) => "GitHub is required for students. LinkedIn is strongly recommended because connecting both improves your chances for selection.",
            (false, true) => "LinkedIn is required for full-time employed applicants. GitHub is strongly recommended because connecting both improves your chances for selection.",
            _ => "Connect both if you can. Verified GitHub and LinkedIn accounts improve your chances for selection, even when only one is required."
        };

    private string GetLinkedInCardDescription()
        => IsLinkedInRequired
            ? "Required for full-time employed applicants. Sign in to LinkedIn so we can capture your verified member ID."
            : "Recommended for everyone. Sign in to LinkedIn so we can capture your verified member ID."
        ;

    private string GetGitHubCardDescription()
        => IsGitHubRequired
            ? "Required for students. Sign in to GitHub so we can capture your verified profile URL."
            : "Recommended for everyone. Sign in to GitHub so we can capture your verified profile URL.";

    private string GetActionHint()
        => _isLoading
            ? "Loading your saved social connections before you continue."
            : HasLoadError
                ? "Refresh the page to reload your saved social connections before you continue."
                : (IsGitHubRequired, IsLinkedInRequired) switch
                {
                    (true, false) => "Connect GitHub to continue. We still strongly recommend LinkedIn too because having both verified accounts improves your chances for selection.",
                    (false, true) => "Connect LinkedIn to continue. We still strongly recommend GitHub too because having both verified accounts improves your chances for selection.",
                    _ => "Connect both accounts if you can. Even when only one is required, having both verified accounts improves your chances for selection."
                };

    private string GetRequiredConnectionError()
        => (IsGitHubRequired, IsLinkedInRequired) switch
        {
            (true, false) => "GitHub is required for students. LinkedIn is still recommended because both verified accounts improve your chances for selection.",
            (false, true) => "LinkedIn is required for full-time employed applicants. GitHub is still recommended because both verified accounts improve your chances for selection.",
            _ => "Connect the required social account before continuing. Connecting both is strongly recommended because both verified accounts improve your chances for selection."
        };

    private string? ResolveSocialErrorMessage()
    {
        if (string.IsNullOrWhiteSpace(SocialErrorQuery))
        {
            return null;
        }

        var providerName = SocialProviderQuery?.Trim().ToLowerInvariant() switch
        {
            "github" => "GitHub",
            "linkedin" => "LinkedIn",
            _ => "This social provider"
        };

        return SocialErrorQuery switch
        {
            "social-provider-not-configured" => $"{providerName} is not configured for local onboarding yet.",
            "social-connect-failed" => $"{providerName} sign-in did not complete. Please try connecting {providerName} again.",
            "social-connect-cancelled" => $"{providerName} sign-in was cancelled before Bethuya could verify the account.",
            "social-provider-scope-not-authorized" => "LinkedIn sign-in is blocked because your LinkedIn app is not approved for the scopes Bethuya requested. Enable the \"Sign in with LinkedIn using OpenID Connect\" product for openid/profile access, or explicitly configure the legacy r_liteprofile scope, and keep https://localhost:7400/oauth/linkedin/callback registered as an allowed redirect URL.",
            "github-connect-incomplete" => "GitHub sign-in succeeded, but we couldn't read the verified GitHub profile details.",
            "linkedin-connect-incomplete" => "LinkedIn sign-in succeeded, but we couldn't read the verified LinkedIn member details.",
            _ => $"{providerName} couldn't complete the social profile connection. Please try again."
        };
    }

    private string? GetProviderSocialErrorMessage(string provider)
        => string.Equals(GetNormalizedSocialProvider(), provider, StringComparison.Ordinal)
            ? _socialErrorMessage
            : null;

    private string? GetNormalizedSocialProvider()
        => SocialProviderQuery?.Trim().ToLowerInvariant() switch
        {
            "github" => "github",
            "linkedin" => "linkedin",
            _ => null
        };

    private string? GetNormalizedLinkedInProfileUrl()
        => string.IsNullOrWhiteSpace(_model.LinkedInProfileUrl)
            ? null
            : _model.LinkedInProfileUrl.Trim();

    private sealed class SocialProfileModel
    {
        public string? OccupationStatus { get; set; }

        public bool IsLinkedInRequired { get; set; }

        public bool IsGitHubRequired { get; set; }

        public string? LinkedInMemberId { get; set; }

        public string? LinkedInProfileUrl { get; set; }

        public string? GitHubLogin { get; set; }

        public string? GitHubProfileUrl { get; set; }
    }
}
