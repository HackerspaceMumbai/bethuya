@page "/events"
@rendermode InteractiveServer
@using Bethuya.Hybrid.Shared.Services
@using Bethuya.Hybrid.Shared.Components.Dashboard
@using Bethuya.Hybrid.Shared.Components
@inject IEventApi EventApi

<PageTitle>Events — Bethuya</PageTitle>

<div data-test="events-page" class="container mx-auto p-4">

    @* Page Header *@
    <div class="flex flex-wrap justify-between items-center mb-6 gap-4">
        <div class="flex items-center gap-3">
            <h1 class="text-2xl font-bold">Events</h1>
            <BbBadge Variant="BadgeVariant.Secondary">@filteredEvents.Count</BbBadge>
        </div>

        <div class="flex items-center gap-3">
            <div data-test="new-event-btn">
                <BbButton Variant="ButtonVariant.Default" OnClick="@(() => Navigation.NavigateTo("/events/create"))">
                    <LucideIcon Name="calendar-plus" Size="16" />
                    New Event
                </BbButton>
            </div>

            <select data-test="status-filter" class="form-select" @bind="statusFilter">
                <option value="All">All Statuses</option>
                <option value="Draft">Draft</option>
                <option value="Planning">Planning</option>
                <option value="RegistrationOpen">Registration Open</option>
                <option value="InProgress">In Progress</option>
                <option value="Completed">Completed</option>
                <option value="Cancelled">Cancelled</option>
            </select>

            <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" OnClick="ToggleSort">
                @(sortAscending ? "Date ↑" : "Date ↓")
            </BbButton>
        </div>
    </div>

    @* Event List *@
    @if (isLoading)
    {
        <div data-test="loading-state" class="p-8 text-center">
            <p>Loading events…</p>
        </div>
    }
    else if (errorMessage is not null)
    {
        <div data-test="error-state">
            <BbAlert Variant="AlertVariant.Danger">
                <BbAlertDescription>@errorMessage</BbAlertDescription>
            </BbAlert>
        </div>
    }
    else if (filteredEvents.Count == 0)
    {
        <BbCard Class="p-8 text-center">
            <p class="text-muted-foreground">No events match the selected filter.</p>
        </BbCard>
    }
    else
    {
        <div class="grid gap-4">
            @foreach (var evt in filteredEvents)
            {
                <div data-test="event-row">
                <BbCard Class="p-4">
                    <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4">
                        <div class="flex-1 min-w-0">
                            <h3 class="text-lg font-semibold mb-1">@evt.Title</h3>
                            <p class="text-sm text-muted-foreground mb-3">@(evt.Description ?? "")</p>

                            <div class="flex flex-wrap gap-2 mb-3">
                                <BbBadge Variant="@GetStatusVariant(evt.Status)">@evt.Status</BbBadge>
                                @if (evt.AgendaStatus is not null)
                                {
                                    <BbBadge Variant="@GetAgendaVariant(evt.AgendaStatus)">@evt.AgendaStatus</BbBadge>
                                }
                                else
                                {
                                    <BbBadge Variant="BadgeVariant.Outline">No Agenda</BbBadge>
                                }
                                <BbBadge Variant="BadgeVariant.Secondary">@evt.Type</BbBadge>
                            </div>

                            <div class="flex flex-wrap gap-4 text-sm text-muted-foreground">
                                <span>📍 @(evt.Location ?? "TBD")</span>
                                <span>👥 @evt.Capacity</span>
                                <span>📅 @evt.StartDate.ToString("MMM dd, yyyy")@(evt.StartDate != evt.EndDate ? $" – {evt.EndDate:MMM dd, yyyy}" : "")</span>
                            </div>
                        </div>

                        <div class="flex gap-2 shrink-0">
                            <div data-test="view-event-btn">
                                <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small"
                                          OnClick="@(() => Navigation.NavigateTo(evt.Hashtag is not null ? $"/events/{evt.Hashtag}" : $"/events/{evt.Id}"))">
                                    Draft Schedule →
                                </BbButton>
                            </div>
                            <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small"
                                      OnClick="@(() => Navigation.NavigateTo($"/events/{evt.Id}/registrations"))">
                                Registrations
                            </BbButton>
                        </div>
                    </div>
                </BbCard>
                </div>
            }
        </div>
    }

    @* ── Notification Toast ── *@
    <Notification @bind-IsVisible="showNotification" Message="@notificationMessage" Variant="@notificationVariant" AutoDismissSeconds="5" />
</div>

@code {
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<EventViewModel> allEvents = [];
    private string statusFilter = "All";
    private bool sortAscending = true;
    private bool isLoading = true;
    private string? errorMessage;
    private bool showNotification;
    private string notificationMessage = string.Empty;
    private AlertVariant notificationVariant = AlertVariant.Success;

    private List<EventViewModel> filteredEvents
    {
        get
        {
            var query = statusFilter == "All"
                ? allEvents.AsEnumerable()
                : allEvents.Where(e => e.Status == statusFilter);

            return sortAscending
                ? query.OrderBy(e => e.StartDate).ToList()
                : query.OrderByDescending(e => e.StartDate).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var dtos = await EventApi.GetAllAsync();
            allEvents = dtos.Select(MapToViewModel).ToList();
        }
        catch (Exception)
        {
            errorMessage = "Failed to load events. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static EventViewModel MapToViewModel(EventDto dto) => new()
    {
        Id = dto.Id,
        Title = dto.Title,
        Description = dto.Description,
        Type = dto.Type,
        Status = dto.Status,
        Capacity = dto.Capacity,
        Location = dto.Location,
        Hashtag = dto.Hashtag,
        StartDate = DateOnly.FromDateTime(dto.StartDate.DateTime),
        EndDate = DateOnly.FromDateTime(dto.EndDate.DateTime)
    };

    private void ToggleSort() => sortAscending = !sortAscending;

    private void HandleNotification(string message)
    {
        notificationMessage = message;
        notificationVariant = message.Contains("successfully", StringComparison.OrdinalIgnoreCase)
            ? AlertVariant.Success
            : AlertVariant.Danger;
        showNotification = true;
    }

    private static BadgeVariant GetStatusVariant(string status) => status switch
    {
        "Draft" => BadgeVariant.Outline,
        "Planning" => BadgeVariant.Secondary,
        "RegistrationOpen" or "InProgress" => BadgeVariant.Default,
        "Completed" => BadgeVariant.Default,
        "Cancelled" => BadgeVariant.Destructive,
        _ => BadgeVariant.Outline
    };

    private static BadgeVariant GetAgendaVariant(string? status) => status switch
    {
        "ProposedByAgent" => BadgeVariant.Secondary,
        "ApprovedByHuman" or "Published" => BadgeVariant.Default,
        "Archived" => BadgeVariant.Destructive,
        _ => BadgeVariant.Outline
    };

}
