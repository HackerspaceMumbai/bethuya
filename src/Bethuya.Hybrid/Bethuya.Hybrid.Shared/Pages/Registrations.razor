@page "/events/{EventId:guid}/registrations"
@attribute [Authorize(Policy = BethuyaAuthorizationPolicies.RequireAttendee)]
@rendermode InteractiveServer
@inject IRegistrationApi RegistrationApi
@using Microsoft.AspNetCore.Components.Forms
@using BlazorBlueprint.Components

<PageTitle>Registrations — Bethuya</PageTitle>

<div class="container mx-auto p-4">
    <BbButton Variant="ButtonVariant.Ghost" OnClick="@(() => Navigation.NavigateTo($"/events/{EventId}"))">
        ← Back to Event
    </BbButton>

    <h1 class="text-2xl font-bold mt-4 mb-6">Registrations</h1>

    @if (_errorMessage is not null)
    {
        <div data-test="registration-error">
            <BbAlert Variant="AlertVariant.Danger" Class="mb-4">
                @_errorMessage
            </BbAlert>
        </div>
    }

    <div class="grid grid-cols-3 gap-6">
        <div class="col-span-2">
            <BbCard Class="p-4">
                <h2 class="text-lg font-semibold mb-4">Registered Attendees</h2>
                @if (registrations.Count == 0)
                {
                    <p class="text-muted-foreground">No registrations yet.</p>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var reg in registrations)
                        {
                            <div class="flex justify-between items-center p-2 border rounded" data-test="registration-row">
                                <div>
                                    <span class="font-medium">@reg.FullName</span>
                                    <span class="text-sm text-muted-foreground ml-2">@reg.Email</span>
                                </div>
                                <BbBadge Variant="@GetStatusVariant(reg.Status)">@reg.Status</BbBadge>
                            </div>
                        }
                    </div>
                }
            </BbCard>
        </div>

        <div>
            <BbCard Class="p-4">
                <h2 class="text-lg font-semibold mb-4">Register</h2>
                <div class="grid gap-4">

                    @* Section 0 — Contact *@
                    <BbFormSection Title="Your Details">
                        <div data-test="registration-name-field">
                            <BbFormFieldInput Label="Full name" @bind-Value="_newName" Required />
                        </div>
                        <div data-test="registration-email-field">
                            <BbFormFieldInput Label="Email" @bind-Value="_newEmail" Required />
                        </div>
                        <div class="form-group" data-test="registration-bio-field">
                            <BbLabel>Short bio (optional)</BbLabel>
                            @* BbFormFieldTextarea does not exist in BB 3.x — using standalone BbTextarea with manual wrapper *@
                            <BbTextarea @bind-Value="_newBio" MaxLength="500" ShowCharacterCount />
                        </div>
                        <div data-test="registration-interests-field">
                            <BbFormFieldInput Label="Interests (comma-separated)" @bind-Value="_newInterests" />
                        </div>
                    </BbFormSection>

                    @* Section 1 — Intent *@
                    <BbFormSection Title="Intent" Description="Help us understand why you want to attend.">
                        <div class="form-group" data-test="registration-why-attend-field">
                            <BbLabel>Why do you want to attend this event? *</BbLabel>
                            @* BbFormFieldTextarea does not exist in BB 3.x — using standalone BbTextarea with manual wrapper *@
                            <BbTextarea @bind-Value="_whyAttend" MaxLength="1000" ShowCharacterCount Required />
                        </div>
                        <div class="form-group" data-test="registration-goals-field">
                            <BbLabel>What do you hope to achieve? (optional)</BbLabel>
                            @* BbFormFieldTextarea does not exist in BB 3.x — using standalone BbTextarea with manual wrapper *@
                            <BbTextarea @bind-Value="_goals" MaxLength="500" ShowCharacterCount />
                        </div>
                        <div class="form-group" data-test="registration-contribution-field">
                            <BbLabel>How would you like to contribute?</BbLabel>
                            <div class="grid gap-1 mt-1">
                                <label class="flex items-center gap-2 text-sm">
                                    <input type="checkbox" @bind="_contribLearn" data-test="contrib-learn" /> Learn
                                </label>
                                <label class="flex items-center gap-2 text-sm">
                                    <input type="checkbox" @bind="_contribHelp" data-test="contrib-help" /> Help others
                                </label>
                                <label class="flex items-center gap-2 text-sm">
                                    <input type="checkbox" @bind="_contribShare" data-test="contrib-share" /> Share knowledge
                                </label>
                                <label class="flex items-center gap-2 text-sm">
                                    <input type="checkbox" @bind="_contribPresent" data-test="contrib-present" /> Present/demo
                                </label>
                            </div>
                        </div>
                    </BbFormSection>

                    @* Section 2 — Experience *@
                    <BbFormSection Title="Experience">
                        <div data-test="registration-experience-field">
                            <BbFormFieldRadioGroup Label="Your experience level" @bind-Value="_experienceLevel">
                                <BbRadioGroupItem Value="@("Beginner")" Label="Beginner" />
                                <BbRadioGroupItem Value="@("Intermediate")" Label="Intermediate" />
                                <BbRadioGroupItem Value="@("Advanced")" Label="Advanced" />
                                <BbRadioGroupItem Value="@("Expert")" Label="Expert" />
                            </BbFormFieldRadioGroup>
                        </div>
                    </BbFormSection>

                    @* Section 3 — Event Requirements *@
                    <BbFormSection Title="Event Requirements">
                        <div class="form-group" data-test="registration-gov-id-field">
                            <BbLabel>Government ID *</BbLabel>
                            @* BB FileUpload has no BbFormFieldFileUpload wrapper — using standalone BbFileUpload with manual wrapper *@
                            <div data-test="gov-id-upload">
                                <BbFileUpload FilesChanged="HandleGovIdSelected"
                                              Accept=".jpg,.jpeg,.png,.pdf"
                                              MaxFileSize="@(10 * 1024 * 1024)"
                                              MaxFileCount="1"
                                              OnValidationError="@(err => _govIdValidationError = err.Message)" />
                            </div>
                            <p class="text-sm text-muted-foreground mt-1">Required for event security. Stored securely.</p>
                            @if (!string.IsNullOrWhiteSpace(_govIdValidationError))
                            {
                                <p class="text-sm text-destructive mt-1">@_govIdValidationError</p>
                            }
                        </div>
                        <div class="form-group" data-test="registration-dietary-field">
                            <BbLabel>Dietary requirements (optional)</BbLabel>
                            @* BbFormFieldTextarea does not exist in BB 3.x — using standalone BbTextarea with manual wrapper *@
                            <BbTextarea @bind-Value="_dietaryRequirements" MaxLength="300" ShowCharacterCount />
                        </div>
                        <div class="form-group" data-test="registration-accessibility-field">
                            <BbLabel>Accessibility needs (optional)</BbLabel>
                            @* BbFormFieldTextarea does not exist in BB 3.x — using standalone BbTextarea with manual wrapper *@
                            <BbTextarea @bind-Value="_accessibilityNeeds" MaxLength="300" ShowCharacterCount />
                        </div>
                    </BbFormSection>

                    <div class="flex items-center gap-2">
                        <input type="checkbox" id="consentCheckbox" @bind="_consentGiven" required data-test="consent-checkbox" />
                        <label for="consentCheckbox" class="text-sm">I consent to the collection and processing of my registration details for fair attendee curation. See our <a href="/privacy" target="_blank" rel="noopener noreferrer">privacy policy</a>.</label>
                    </div>

                    <div data-test="submit-registration-btn">
                        <BbButton Variant="ButtonVariant.Default" OnClick="Register" Disabled="@(!_consentGiven || _isSubmitting)">Submit Registration</BbButton>
                    </div>

                </div>
            </BbCard>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid EventId { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<RegistrationDto> registrations = [];

    // Contact
    private string _newName = "";
    private string _newEmail = "";
    private string _newBio = "";
    private string _newInterests = "";

    // Section 1 — Intent
    private string _whyAttend = "";
    private string _goals = "";
    private bool _contribLearn;
    private bool _contribHelp;
    private bool _contribShare;
    private bool _contribPresent;

    // Section 2 — Experience
    private string _experienceLevel = "";

    // Section 3 — Event Requirements
    private IBrowserFile? _governmentIdFile;
    private string _govIdValidationError = "";
    private string _dietaryRequirements = "";
    private string _accessibilityNeeds = "";

    // Consent & submit state
    private bool _consentGiven;
    private bool _isSubmitting;
    private string? _errorMessage;

    /// <summary>
    /// Holds the registration ID after create succeeds but before Gov ID upload succeeds.
    /// Prevents duplicate registration records when the user retries an upload failure.
    /// </summary>
    private Guid? _pendingRegistrationId;

    protected override async Task OnParametersSetAsync()
    {
        _errorMessage = null;

        try
        {
            registrations = await RegistrationApi.GetByEventIdAsync(EventId);
        }
        catch (Refit.ApiException)
        {
            registrations = [];
            _errorMessage = "We couldn't load registrations right now. Please try again.";
        }
        catch (HttpRequestException)
        {
            registrations = [];
            _errorMessage = "Unable to reach the server. Please check your connection and try again.";
        }
        catch (TaskCanceledException)
        {
            registrations = [];
            _errorMessage = "The request timed out. Please try again.";
        }
    }

    private void HandleGovIdSelected(IReadOnlyList<FileUploadItem> files)
    {
        _govIdValidationError = "";
        _governmentIdFile = files.Count > 0 ? files[0].File : null;
    }

    private async Task Register()
    {
        if (_isSubmitting)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_newName) || string.IsNullOrWhiteSpace(_newEmail) || !_consentGiven)
        {
            _errorMessage = "Full name, email, and consent are required before submitting.";
            return;
        }

        if (!_newEmail.Contains('@') || !_newEmail.Contains('.'))
        {
            _errorMessage = "Enter a valid email address.";
            return;
        }

        if (string.IsNullOrWhiteSpace(_whyAttend))
        {
            _errorMessage = "Please tell us why you want to attend — this is required.";
            return;
        }

        if (_governmentIdFile is null)
        {
            _errorMessage = "A Government ID upload is required for event security.";
            return;
        }

        _errorMessage = null;
        _isSubmitting = true;

        try
        {
            // Step 1 — Create registration (skip if retrying after a failed upload)
            if (_pendingRegistrationId is null)
            {
                var contributions = BuildContributionList();
                var created = await RegistrationApi.CreateAsync(new CreateRegistrationDto(
                    EventId,
                    _newName,
                    _newEmail,
                    string.IsNullOrWhiteSpace(_newBio) ? null : _newBio,
                    _newInterests.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList(),
                    _whyAttend.Trim(),
                    string.IsNullOrWhiteSpace(_goals) ? null : _goals.Trim(),
                    contributions,
                    string.IsNullOrWhiteSpace(_experienceLevel) ? null : _experienceLevel,
                    string.IsNullOrWhiteSpace(_dietaryRequirements) ? null : _dietaryRequirements.Trim(),
                    string.IsNullOrWhiteSpace(_accessibilityNeeds) ? null : _accessibilityNeeds.Trim()));

                registrations.Add(created);
                _pendingRegistrationId = created.Id;
            }

            // Step 2 — Upload Government ID
            await using var stream = _governmentIdFile!.OpenReadStream(maxAllowedSize: 10L * 1024 * 1024);
            var part = new Refit.StreamPart(stream, _governmentIdFile.Name, _governmentIdFile.ContentType);
            await RegistrationApi.UploadGovernmentIdAsync(_pendingRegistrationId!.Value, part);

            // Both steps succeeded — reset form
            ResetForm();
        }
        catch (Refit.ApiException ex) when (_pendingRegistrationId is not null)
        {
            _errorMessage = $"Registration saved, but ID upload failed (HTTP {(int)ex.StatusCode}). Click 'Submit Registration' again to retry the upload.";
        }
        catch (Refit.ApiException)
        {
            _errorMessage = "We couldn't save your registration right now. Please try again.";
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to reach the server. Please check your connection and try again.";
        }
        catch (TaskCanceledException)
        {
            _errorMessage = "The request timed out. Please try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private List<string> BuildContributionList()
    {
        List<string> list = [];
        if (_contribLearn) list.Add("Learn");
        if (_contribHelp) list.Add("Help others");
        if (_contribShare) list.Add("Share knowledge");
        if (_contribPresent) list.Add("Present/demo");
        return list;
    }

    private void ResetForm()
    {
        _newName = "";
        _newEmail = "";
        _newBio = "";
        _newInterests = "";
        _whyAttend = "";
        _goals = "";
        _contribLearn = false;
        _contribHelp = false;
        _contribShare = false;
        _contribPresent = false;
        _experienceLevel = "";
        _governmentIdFile = null;
        _govIdValidationError = "";
        _dietaryRequirements = "";
        _accessibilityNeeds = "";
        _consentGiven = false;
        _pendingRegistrationId = null;
    }

    private static BadgeVariant GetStatusVariant(string status) => status switch
    {
        "Accepted" => BadgeVariant.Default,
        "Waitlisted" => BadgeVariant.Secondary,
        "Rejected" => BadgeVariant.Destructive,
        _ => BadgeVariant.Outline
    };
}
