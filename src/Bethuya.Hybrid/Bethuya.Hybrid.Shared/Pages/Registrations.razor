@page "/events/{EventId:guid}/registrations"
@attribute [Authorize(Policy = BethuyaAuthorizationPolicies.RequireAttendee)]
@rendermode InteractiveServer
@inject IRegistrationApi RegistrationApi

<PageTitle>Registrations — Bethuya</PageTitle>

<div class="container mx-auto p-4">
    <BbButton Variant="ButtonVariant.Ghost" OnClick="@(() => Navigation.NavigateTo($"/events/{EventId}"))">
        ← Back to Event
    </BbButton>

    <h1 class="text-2xl font-bold mt-4 mb-6">Registrations</h1>

    @if (_errorMessage is not null)
    {
        <div data-test="registration-error">
            <BbAlert Variant="AlertVariant.Danger" Class="mb-4">
                @_errorMessage
            </BbAlert>
        </div>
    }

    <div class="grid grid-cols-3 gap-6">
        <div class="col-span-2">
            <BbCard Class="p-4">
                <h2 class="text-lg font-semibold mb-4">Registered Attendees</h2>
                @if (registrations.Count == 0)
                {
                    <p class="text-muted-foreground">No registrations yet.</p>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var reg in registrations)
                        {
                            <div class="flex justify-between items-center p-2 border rounded" data-test="registration-row">
                                <div>
                                    <span class="font-medium">@reg.FullName</span>
                                    <span class="text-sm text-muted-foreground ml-2">@reg.Email</span>
                                </div>
                                <BbBadge Variant="@GetStatusVariant(reg.Status)">@reg.Status</BbBadge>
                            </div>
                        }
                    </div>
                }
            </BbCard>
        </div>

        <div>
            <BbCard Class="p-4">
                <h2 class="text-lg font-semibold mb-4">Register</h2>
                    <div class="grid gap-3">
                        <div data-test="registration-name-field">
                            <BbInput @bind-Value="newName" Placeholder="Full name" />
                        </div>
                        <div data-test="registration-email-field">
                            <BbInput @bind-Value="newEmail" Placeholder="Email" />
                        </div>
                        <div data-test="registration-bio-field">
                            <BbTextarea @bind-Value="newBio" Placeholder="Short bio (optional)" />
                        </div>
                        <div data-test="registration-interests-field">
                            <BbInput @bind-Value="newInterests" Placeholder="Interests (comma-separated)" />
                        </div>
                        <div data-test="registration-neighborhood-field">
                            <BbInput @bind-Value="newNeighborhood" Placeholder="Neighbourhood / area (required for curation)" />
                        </div>
                        <div data-test="registration-languages-field">
                            <BbInput @bind-Value="newLanguageProficiency" Placeholder="Languages spoken (required for curation)" />
                        </div>
                        <div data-test="registration-education-field">
                            <BbInput @bind-Value="newEducationalBackground" Placeholder="Highest education level (required for curation)" />
                        </div>
                        <div data-test="registration-socioeconomic-field">
                            <BbInput @bind-Value="newSocioeconomicBackground" Placeholder="Socioeconomic background (required for curation)" />
                        </div>
                    <div class="flex items-center gap-2">
                        <input type="checkbox" id="consentCheckbox" @bind="consentGiven" required data-test="consent-checkbox" />
                        <label for="consentCheckbox" class="text-sm">I consent to the collection and processing of my registration details (including curation context) for fair attendee curation. See our <a href="/privacy" target="_blank" rel="noopener noreferrer">privacy policy</a>.</label>
                    </div>
                    <div data-test="submit-registration-btn">
                        <BbButton Variant="ButtonVariant.Default" OnClick="Register" Disabled="@(!consentGiven)">Submit Registration</BbButton>
                    </div>
                </div>
            </BbCard>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid EventId { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<RegistrationDto> registrations = [];
    private string newName = "";
    private string newEmail = "";
    private string newBio = "";
    private string newInterests = "";
    private string newNeighborhood = "";
    private string newLanguageProficiency = "";
    private string newEducationalBackground = "";
    private string newSocioeconomicBackground = "";
    private bool consentGiven = false;
    private string? _errorMessage;

    protected override async Task OnParametersSetAsync()
    {
        _errorMessage = null;

        try
        {
            registrations = await RegistrationApi.GetByEventIdAsync(EventId);
        }
        catch (Refit.ApiException)
        {
            registrations = [];
            _errorMessage = "We couldn't load registrations right now. Please try again.";
        }
        catch (HttpRequestException)
        {
            registrations = [];
            _errorMessage = "Unable to reach the server. Please check your connection and try again.";
        }
        catch (TaskCanceledException)
        {
            registrations = [];
            _errorMessage = "The request timed out. Please try again.";
        }
    }

    // User must provide explicit consent before registration (PII compliance for Email)
    private async Task Register()
    {
        if (string.IsNullOrWhiteSpace(newName) || string.IsNullOrWhiteSpace(newEmail) || !consentGiven)
        {
            _errorMessage = "Full name, email, and consent are required before submitting registration.";
            return;
        }

        if (!newEmail.Contains('@') || !newEmail.Contains('.'))
        {
            _errorMessage = "Enter a valid email address before submitting registration.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newNeighborhood)
            || string.IsNullOrWhiteSpace(newLanguageProficiency)
            || string.IsNullOrWhiteSpace(newEducationalBackground)
            || string.IsNullOrWhiteSpace(newSocioeconomicBackground))
        {
            _errorMessage = "Neighbourhood, languages, education, and socioeconomic background are required for curation.";
            return;
        }

        _errorMessage = null;

        try
        {
            var created = await RegistrationApi.CreateAsync(new CreateRegistrationDto(
                EventId,
                newName,
                newEmail,
                string.IsNullOrWhiteSpace(newBio) ? null : newBio,
                newInterests.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList(),
                newNeighborhood.Trim(),
                newLanguageProficiency.Trim(),
                newEducationalBackground.Trim(),
                newSocioeconomicBackground.Trim()));

            registrations.Add(created);

            newName = "";
            newEmail = "";
            newBio = "";
            newInterests = "";
            newNeighborhood = "";
            newLanguageProficiency = "";
            newEducationalBackground = "";
            newSocioeconomicBackground = "";
            consentGiven = false;
        }
        catch (Refit.ApiException)
        {
            _errorMessage = "We couldn't save your registration right now. Please try again.";
        }
        catch (HttpRequestException)
        {
            _errorMessage = "Unable to reach the server. Please check your connection and try again.";
        }
        catch (TaskCanceledException)
        {
            _errorMessage = "The request timed out. Please try again.";
        }
    }

    private static BadgeVariant GetStatusVariant(string status) => status switch
    {
        "Accepted" => BadgeVariant.Default,
        "Waitlisted" => BadgeVariant.Secondary,
        "Rejected" => BadgeVariant.Destructive,
        _ => BadgeVariant.Outline
    };
}
