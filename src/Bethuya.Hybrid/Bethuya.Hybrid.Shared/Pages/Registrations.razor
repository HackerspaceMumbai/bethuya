@page "/events/{EventId:guid}/registrations"
@attribute [Authorize(Policy = BethuyaAuthorizationPolicies.RequireAttendee)]

<PageTitle>Registrations — Bethuya</PageTitle>

<div class="container mx-auto p-4">
    <BbButton Variant="ButtonVariant.Ghost" OnClick="@(() => Navigation.NavigateTo($"/events/{EventId}"))">
        ← Back to Event
    </BbButton>

    <h1 class="text-2xl font-bold mt-4 mb-6">Registrations</h1>

    <div class="grid grid-cols-3 gap-6">
        <div class="col-span-2">
            <BbCard Class="p-4">
                <h2 class="text-lg font-semibold mb-4">Registered Attendees</h2>
                @if (registrations.Count == 0)
                {
                    <p class="text-muted-foreground">No registrations yet.</p>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var reg in registrations)
                        {
                            <div class="flex justify-between items-center p-2 border rounded" data-test="registration-row">
                                <div>
                                    <span class="font-medium">@reg.FullName</span>
                                    <span class="text-sm text-muted-foreground ml-2">@reg.Email</span>
                                </div>
                                <BbBadge Variant="@GetStatusVariant(reg.Status)">@reg.Status</BbBadge>
                            </div>
                        }
                    </div>
                }
            </BbCard>
        </div>

        <div>
            <BbCard Class="p-4">
                <h2 class="text-lg font-semibold mb-4">Register</h2>
                <div class="grid gap-3">
                    <BbInput @bind-Value="newName" Placeholder="Full name" />
                    <BbInput @bind-Value="newEmail" Placeholder="Email" />
                    <BbTextarea @bind-Value="newBio" Placeholder="Short bio (optional)" />
                    <BbInput @bind-Value="newInterests" Placeholder="Interests (comma-separated)" />
                    <BbButton Variant="ButtonVariant.Default" OnClick="Register">Submit Registration</BbButton>
                </div>
            </BbCard>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid EventId { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private List<RegistrationViewModel> registrations = [];
    private string newName = "";
    private string newEmail = "";
    private string newBio = "";
    private string newInterests = "";

    private void Register()
    {
        if (string.IsNullOrWhiteSpace(newName) || string.IsNullOrWhiteSpace(newEmail)) return;

        registrations.Add(new RegistrationViewModel
        {
            FullName = newName,
            Email = newEmail,
            Bio = newBio,
            Interests = newInterests.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList(),
            Status = "Pending"
        });

        newName = "";
        newEmail = "";
        newBio = "";
        newInterests = "";
    }

    private static BadgeVariant GetStatusVariant(string status) => status switch
    {
        "Accepted" => BadgeVariant.Default,
        "Waitlisted" => BadgeVariant.Secondary,
        "Rejected" => BadgeVariant.Destructive,
        _ => BadgeVariant.Outline
    };

    private sealed class RegistrationViewModel
    {
        public string FullName { get; set; } = "";
        public string Email { get; set; } = "";
        public string? Bio { get; set; }
        public List<string> Interests { get; set; } = [];
        public string Status { get; set; } = "Pending";
    }
}
