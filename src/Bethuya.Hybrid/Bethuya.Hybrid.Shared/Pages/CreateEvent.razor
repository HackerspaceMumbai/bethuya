@page "/events/create"
@rendermode InteractiveServer
@using Bethuya.Hybrid.Shared.Models
@using Bethuya.Hybrid.Shared.Services
@inject IEventApi EventApi
@inject NavigationManager Navigation

<PageTitle>Create Event — Bethuya</PageTitle>

<div data-test="create-event-page" class="create-event-page">

    <BbButton Variant="ButtonVariant.Ghost" OnClick="@(() => Navigation.NavigateTo("/events"))">
        ← Back to Events
    </BbButton>

    <BbCard Class="mt-6">
        <BbCardHeader>
            <BbCardTitle Class="text-2xl">Create Event</BbCardTitle>
            <BbCardDescription>Fill in the details below to create a new community event draft.</BbCardDescription>
        </BbCardHeader>

        <EditForm Model="@_formModel" OnValidSubmit="HandleValidSubmit" FormName="create-event" data-test="create-event-form">
            <DataAnnotationsValidator />

            <BbCardContent>
                <div class="form-fields">

                    <div class="form-group">
                        <BbLabel For="newTitle">Title *</BbLabel>
                        <BbInput id="newTitle" @bind-Value="_formModel.Title" Placeholder="Event title" Class="w-full" />
                        <ValidationMessage For="@(() => _formModel.Title)" />
                    </div>

                    <div class="form-row-2col">
                        <div class="form-group">
                            <BbLabel For="newHashtag">Hashtag</BbLabel>
                            <div class="hashtag-inline">
                                <span class="hashtag-prefix">#</span>
                                <BbInput id="newHashtag" @bind-Value="_formModel.Hashtag" Placeholder="CopilotDevDays" Class="w-full" />
                            </div>
                            <p class="field-hint">Optional event shortcode.</p>
                        </div>

                        <div class="form-group">
                            <BbLabel For="newType">Event Type</BbLabel>
                            <BbSelect @bind-Value="_formModel.Type">
                                <BbSelectTrigger>
                                    <BbSelectValue Placeholder="Select type" />
                                </BbSelectTrigger>
                                <BbSelectContent>
                                    <BbSelectItem TValue="string" Value="@("Workshop")" Text="Workshop">Workshop</BbSelectItem>
                                    <BbSelectItem TValue="string" Value="@("Meetup")" Text="Meetup">Meetup</BbSelectItem>
                                    <BbSelectItem TValue="string" Value="@("Hackathon")" Text="Hackathon">Hackathon</BbSelectItem>
                                    <BbSelectItem TValue="string" Value="@("Conference")" Text="Conference">Conference</BbSelectItem>
                                    <BbSelectItem TValue="string" Value="@("Panel")" Text="Panel">Panel</BbSelectItem>
                                    <BbSelectItem TValue="string" Value="@("Social")" Text="Social">Social</BbSelectItem>
                                </BbSelectContent>
                            </BbSelect>
                            <ValidationMessage For="@(() => _formModel.Type)" />
                        </div>
                    </div>

                    <div class="form-group">
                        <BbLabel For="newDescription">Description</BbLabel>
                        <BbTextarea id="newDescription" @bind-Value="_formModel.Description" Placeholder="Event description" Class="w-full" />
                        <ValidationMessage For="@(() => _formModel.Description)" />
                    </div>

                    <div class="form-row-2col">
                        <div class="form-group">
                            <BbLabel For="newLocation">Venue</BbLabel>
                            <BbInput id="newLocation" @bind-Value="_formModel.Location" Placeholder="Venue name or address" Class="w-full" />
                            <ValidationMessage For="@(() => _formModel.Location)" />
                        </div>

                        <div class="form-group">
                            <BbLabel For="newCapacity">Capacity</BbLabel>
                            <InputNumber id="newCapacity" @bind-Value="_formModel.Capacity" class="field-input" />
                            <ValidationMessage For="@(() => _formModel.Capacity)" />
                        </div>
                    </div>

                    <div class="form-row-2col">
                        <div class="form-group">
                            <BbLabel For="newStartDate">Start Date</BbLabel>
                            <div data-test="start-date-picker">
                                <BbDatePicker id="newStartDate" @bind-Value="_formModel.StartDate"
                                              Placeholder="Pick a date" MinDate="DateTime.Today" Class="w-full" />
                            </div>
                            <ValidationMessage For="@(() => _formModel.StartDate)" />
                        </div>

                        <div class="form-group">
                            <BbLabel>Start Time</BbLabel>
                            <div data-test="start-time-picker">
                                <BbTimePicker @bind-Value="_formModel.StartTime"
                                              Placeholder="Pick a time" Class="w-full" />
                            </div>
                        </div>
                    </div>

                    <div class="form-row-2col">
                        <div class="form-group">
                            <BbLabel For="newEndDate">End Date</BbLabel>
                            <div data-test="end-date-picker">
                                <BbDatePicker id="newEndDate" @bind-Value="_formModel.EndDate"
                                              Placeholder="Pick a date" MinDate="DateTime.Today" Class="w-full" />
                            </div>
                            <ValidationMessage For="@(() => _formModel.EndDate)" />
                        </div>

                        <div class="form-group">
                            <BbLabel>End Time</BbLabel>
                            <div data-test="end-time-picker">
                                <BbTimePicker @bind-Value="_formModel.EndTime"
                                              Placeholder="Pick a time" Class="w-full" />
                            </div>
                        </div>
                    </div>

                    <div class="form-group" data-test="cover-image-section">
                        <BbLabel>Cover Image</BbLabel>
                        <div class="cover-upload-area">
                            @if (_formModel.CoverImageUrl is not null)
                            {
                                <div class="cover-preview" data-test="cover-image-preview">
                                    <img src="@_formModel.CoverImageUrl" alt="Cover preview" class="cover-preview-img" />
                                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small"
                                              OnClick="RemoveCoverImage" Disabled="@_isUploading"
                                              data-test="remove-cover-btn">
                                        Remove
                                    </BbButton>
                                </div>
                            }
                            else
                            {
                                <div class="cover-dropzone" data-test="cover-image-dropzone">
                                    <InputFile OnChange="HandleCoverImageSelected" accept="image/jpeg,image/png,image/webp,image/gif"
                                               data-test="cover-image-input" />
                                    <p class="field-hint">JPEG, PNG, WebP, or GIF — max 5 MB</p>
                                </div>
                            }
                            @if (_isUploading)
                            {
                                <p class="field-hint" data-test="upload-progress">Uploading…</p>
                            }
                            @if (_uploadError is not null)
                            {
                                <div data-test="upload-error">
                                    <BbAlert Variant="AlertVariant.Danger">@_uploadError</BbAlert>
                                </div>
                            }
                        </div>
                    </div>

                    @if (_errorMessage is not null)
                    {
                        <div data-test="create-error">
                            <BbAlert Variant="AlertVariant.Danger">@_errorMessage</BbAlert>
                        </div>
                    }

                </div>
            </BbCardContent>

            <BbCardFooter Class="justify-between">
                    <BbButton Variant="ButtonVariant.Outline" OnClick="HandleCancel" Disabled="@_isSaving">
                        Cancel
                    </BbButton>
                    <div data-test="create-event-submit">
                        <BbButton Variant="ButtonVariant.Default" Type="ButtonType.Submit" Disabled="@_isSaving">
                            @(_isSaving ? "Creating…" : "Create Event")
                        </BbButton>
                    </div>
            </BbCardFooter>

        </EditForm>
    </BbCard>
</div>

@code {
    private CreateEventFormModel _formModel = new();
    private bool _isSaving;
    private string? _errorMessage;
    private bool _isUploading;
    private string? _uploadError;

    private async Task HandleValidSubmit()
    {
        _isSaving = true;
        _errorMessage = null;

        try
        {
            var dto = new CreateEventDto(
                Title: _formModel.Title,
                Description: _formModel.Description,
                Type: _formModel.Type,
                Capacity: _formModel.Capacity,
                StartDate: new DateTimeOffset(_formModel.StartDate!.Value.Date + (_formModel.StartTime ?? TimeSpan.Zero), TimeSpan.Zero),
                EndDate: new DateTimeOffset(_formModel.EndDate!.Value.Date + (_formModel.EndTime ?? TimeSpan.Zero), TimeSpan.Zero),
                Location: _formModel.Location,
                CreatedBy: "organizer@hackmum.org",
                Hashtag: string.IsNullOrWhiteSpace(_formModel.Hashtag) ? null : _formModel.Hashtag,
                CoverImageUrl: _formModel.CoverImageUrl);

            await EventApi.CreateAsync(dto);
            Navigation.NavigateTo("/events");
        }
        catch (Exception)
        {
            _errorMessage = "Failed to create event. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleCoverImageSelected(InputFileChangeEventArgs e)
    {
        _uploadError = null;
        var file = e.File;

        if (file.Size > 5 * 1024 * 1024)
        {
            _uploadError = "File size must not exceed 5 MB.";
            return;
        }

        _isUploading = true;
        StateHasChanged();

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            var streamPart = new Refit.StreamPart(ms, file.Name, file.ContentType);
            var response = await EventApi.UploadImageAsync(streamPart);
            _formModel.CoverImageUrl = response.Url;
        }
        catch (Exception)
        {
            _uploadError = "Failed to upload image. Please try again.";
        }
        finally
        {
            _isUploading = false;
        }
    }

    private void RemoveCoverImage(MouseEventArgs _)
    {
        _formModel.CoverImageUrl = null;
        _uploadError = null;
    }

    private void HandleCancel()
    {
        Navigation.NavigateTo("/events");
    }
}
