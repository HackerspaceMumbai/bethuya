@page "/events/{EventId:guid}"
@page "/events/{Slug}"
@using Bethuya.Hybrid.Shared.Services
@inject IEventApi EventApi
@inject IPlanningCycleApi PlanningCycleApi

<PageTitle>Event Details - Bethuya</PageTitle>

<div class="container mx-auto p-4">
    @* Header Section *@
    <BbButton Variant="ButtonVariant.Ghost" OnClick="@(() => Navigation.NavigateTo("/"))">
        ← Back to Dashboard
    </BbButton>

    <div class="mt-4 mb-6">
        <div class="flex items-center gap-3 mb-1">
            <h1 class="text-2xl font-bold">@eventTitle</h1>
            @if (agendaStatus == ScheduleStatus.ProposedByAgent)
            {
                <span class="status-badge-proposed-by-agent" aria-label="Proposed by Agent">
                    <span aria-hidden="true">🤖</span> Proposed by Agent
                </span>
            }
            else
            {
                <BbBadge Variant="@GetStatusBadgeVariant(agendaStatus)">
                    @GetStatusDisplayText(agendaStatus)
                </BbBadge>
            }
        </div>
        <p class="text-sm text-muted-foreground">
            @if (_resolvedHashtag is not null)
            {
                <span>#@_resolvedHashtag</span>
            }
            else
            {
                <span>Event ID: @EventId</span>
            }
        </p>
    </div>

    @* Agent Session status bar — compact telemetry strip above the command-center grid *@
    <div data-test="agent-session-status" class="agent-session-status mb-4" role="status" aria-label="Agent session status">
        <span class="agent-session-label" aria-hidden="true">Agent Session</span>
        <div class="agent-session-pills">
            <span data-test="agent-session-cycle-id" class="agent-session-pill">
                <span class="agent-session-pill-key">Cycle</span>
                <span class="agent-session-pill-val">@GetShortCycleId()</span>
            </span>
            <span data-test="agent-session-thread-id" class="agent-session-pill">
                <span class="agent-session-pill-key">Thread</span>
                <span class="agent-session-pill-val">@GetShortConversationId()</span>
            </span>
            <span data-test="agent-session-agent-status" class="agent-session-pill agent-session-pill--status @GetAgentStatusPillClass()" aria-label="Agent status: @GetAgentStatusText()">
                @if (isAiDrafting)
                {
                    <span class="agent-session-pulse" aria-hidden="true"></span>
                }
                @GetAgentStatusText()
            </span>
        </div>
    </div>

    @* Schedule Editor - agent-console three-column layout *@
    <div data-test="schedule-editor" class="grid grid-cols-1 gap-4 xl:grid-cols-12 xl:gap-6">

        @* ── Left Panel: Agent Console ── *@
        <aside class="xl:col-span-3 space-y-4">

            @* === Primary console card: header + draft button + live thread === *@
            <BbCard Class="p-4 border border-border bg-card agent-console-card">

                @* Header row: status light + title + inline cycle metadata *@
                <div class="agent-console-header mb-3">
                    <div class="flex items-start justify-between gap-2">
                        <div class="flex items-center gap-2">
                            <span class="@GetStatusDotClass()" aria-hidden="true"></span>
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.22em] text-muted-foreground">Planner</p>
                                <h2 class="text-base font-semibold leading-tight">Agent Console</h2>
                            </div>
                        </div>
                        @if (agendaStatus == ScheduleStatus.ProposedByAgent)
                        {
                            <span class="status-badge-proposed-by-agent" aria-label="Proposed by Agent">
                                <span aria-hidden="true">🤖</span> Proposed
                            </span>
                        }
                        else
                        {
                            <BbBadge Variant="@GetStatusBadgeVariant(agendaStatus)">
                                @GetStatusDisplayText(agendaStatus)
                            </BbBadge>
                        }
                    </div>

                    <div data-test="planner-cycle-meta" class="agent-console-inline-meta mt-3" aria-label="Planner cycle metadata">
                        <span class="agent-console-meta-pill">
                            <span class="agent-console-meta-key">Cycle</span>
                            <span class="agent-console-meta-value">@GetShortCycleId()</span>
                        </span>
                        <span class="agent-console-meta-pill">
                            <span class="agent-console-meta-key">Thread</span>
                            <span class="agent-console-meta-value">@GetShortConversationId()</span>
                        </span>
                        <span class="agent-console-meta-pill agent-console-meta-pill--status @GetAgentStatusPillClass()" aria-label="Agent status: @GetAgentStatusText()">
                            @if (isAiDrafting)
                            {
                                <span class="agent-console-meta-pulse" aria-hidden="true"></span>
                            }
                            <span class="agent-console-meta-key">Status</span>
                            <span class="agent-console-meta-value">@GetAgentStatusText()</span>
                        </span>
                    </div>
                </div>

                @* Primary action — full-width accented CTA; BB Default variant doesn't expose w-full, so we wrap with ai-draft-cta for block stretch *@
                <div data-test="ai-draft-btn" class="ai-draft-cta mb-4">
                    @if (isAiDrafting)
                    {
                        <BbButton Variant="ButtonVariant.Default" Disabled="true">
                            ⏳ Generating draft…
                        </BbButton>
                    }
                    else
                    {
                        <BbButton Variant="ButtonVariant.Default"
                                  OnClick="@(() => DraftWithAiAsync())"
                                  Disabled="@isCyclePublished">
                            🤖 Draft Schedule with AI
                        </BbButton>
                    }
                </div>

                @* Conversational thread *@
                <div class="agent-console-thread" data-test="agent-console-thread"
                     aria-label="Agent conversation thread" aria-live="polite">
                    @foreach (var msg in _consoleMessages)
                    {
                        <div class="agent-console-msg agent-console-msg--@msg.Role.ToLowerInvariant()">
                            <span class="agent-console-msg-role">@msg.Role</span>
                            <div class="agent-console-msg-body @(msg.IsStreaming ? "agent-console-msg-body--streaming" : "")">
                                @msg.Text
                                @if (msg.IsStreaming)
                                {
                                    <span class="agent-console-type-caret" aria-hidden="true"></span>
                                }
                            </div>
                        </div>
                    }
                    @if (isAiDrafting)
                    {
                        <div class="agent-console-msg agent-console-msg--planner">
                            <span class="agent-console-msg-role">Planner</span>
                            <div class="agent-console-live-status" aria-label="Planner is generating schedule">
                                <span>@(_plannerLiveStatus ?? "Planner is generating schedule")</span>
                                <span class="agent-console-dots" aria-hidden="true"><span></span><span></span><span></span></span>
                            </div>
                        </div>
                        <div class="agent-console-reasoning-steps" data-test="agent-console-reasoning-steps" aria-label="Planner intermediate reasoning steps">
                            @for (var stepIndex = 0; stepIndex < PlannerReasoningSteps.Length; stepIndex++)
                            {
                                var stepClass = GetPlannerReasoningStepClass(stepIndex);
                                <div class="@stepClass">
                                    <span class="agent-console-reasoning-dot" aria-hidden="true"></span>
                                    <span>@PlannerReasoningSteps[stepIndex]</span>
                                </div>
                            }
                        </div>
                    }
                </div>
            </BbCard>

            @* === Refine schedule: organizer inputs + prompt chips === *@
            <BbCard Class="p-4 border border-border bg-card">
                <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Refine Schedule</p>

                <div class="space-y-3 mb-4" data-test="refine-inputs">
                    <div>
                        <p class="mb-1 text-xs font-medium text-muted-foreground">Constraints</p>
                        @* BB ShowPreview not applicable; BbTextarea is the correct standalone component *@
                        <BbTextarea @bind-Value="_refineConstraints"
                                    Placeholder="e.g. keep under 3 hours, must include Q&A"
                                    Rows="2" />
                    </div>
                    <div>
                        <p class="mb-1 text-xs font-medium text-muted-foreground">Target Duration (min)</p>
                        @* Native number input: BbNumericInput generic type inference is unclear for nullable int without a confirmed build check *@
                        <input type="number"
                               min="30" max="480" step="15"
                               value="@(_targetDurationMinutes?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? "")"
                               @onchange="UpdateTargetDuration"
                               placeholder="e.g. 180"
                               class="flex h-9 w-full rounded-md border border-input bg-transparent px-3 py-1 text-sm" />
                    </div>
                </div>

                @* Prompt chips — steer the planner through the same draft invocation path *@
                <div class="flex flex-wrap gap-2" data-test="prompt-chips">
                    <button class="agent-console-chip" data-test="chip-shorten-event"
                            @onclick="ChipShortenEventAsync"
                            disabled="@(isCyclePublished || isAiDrafting)"
                            type="button">
                        ✂ shorten event
                    </button>
                    <button class="agent-console-chip" data-test="chip-add-networking"
                            @onclick="ChipAddNetworkingAsync"
                            disabled="@(isCyclePublished || isAiDrafting)"
                            type="button">
                        🤝 add networking
                    </button>
                    <button class="agent-console-chip" data-test="chip-rebalance"
                            @onclick="ChipRebalanceAsync"
                            disabled="@(isCyclePublished || isAiDrafting)"
                            type="button">
                        ⟳ rebalance
                    </button>
                </div>
                @if (!string.IsNullOrWhiteSpace(_applyingSteeringLabel))
                {
                    <div class="agent-steering-applying mt-3" data-test="agent-steering-applying" role="status" aria-live="polite">
                        <span class="agent-console-meta-pulse" aria-hidden="true"></span>
                        Applying: @_applyingSteeringLabel
                    </div>
                }
            </BbCard>

            @if (!string.IsNullOrWhiteSpace(statusMessage))
            {
                <BbCard Class="p-3 border border-border bg-card">
                    <p class="text-sm">@statusMessage</p>
                </BbCard>
            }
        </aside>

        @* ── Middle Panel: Dominant timeline agenda editor ── *@
        <main class="xl:col-span-6 space-y-4">
            <BbCard Class="p-5 border border-border bg-card">
                <div class="mb-5 flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                    <div>
                        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-muted-foreground">Timeline Agenda</p>
                        <h2 class="mt-1 text-2xl font-bold">Run of Show</h2>
                        <p class="mt-1 text-sm text-muted-foreground">
                            @sessions.Count block@(sessions.Count == 1 ? "" : "s") arranged along the planning timeline.
                        </p>
                    </div>
                    <div class="flex flex-wrap items-center gap-2">
                        <button type="button"
                                class="agent-timeline-toggle @(_showAgentTimeline ? "is-active" : "")"
                                data-test="show-agent-timeline-toggle"
                                aria-pressed="@_showAgentTimeline"
                                @onclick="ToggleAgentTimeline">
                            ✦ Show Agent Timeline
                        </button>
                        <div data-test="add-session-btn">
                            <BbButton Variant="ButtonVariant.Outline"
                                      Size="ButtonSize.Small"
                                      OnClick="@(() => showAddForm = true)">
                                + Add Session
                            </BbButton>
                        </div>
                        <BbButton Variant="ButtonVariant.Ghost"
                                  Size="ButtonSize.Small"
                                  OnClick="ClearAll">
                            Clear All
                        </BbButton>
                    </div>
                </div>

                @if (isAiDrafting && sessions.Count == 0)
                {
                    @* Shimmer skeleton loaders — BB has no skeleton primitives; CSS-only shimmer *@
                    <div class="event-flow-timeline" data-test="timeline-skeleton"
                         role="status" aria-live="polite" aria-label="Generating schedule blocks…">
                        @for (int skIdx = 0; skIdx < 4; skIdx++)
                        {
                            <div class="event-flow-item timeline-skeleton-item" aria-hidden="true">
                                <div class="event-flow-time-axis">
                                    <span class="timeline-sk timeline-sk--time"></span>
                                    <span class="timeline-sk--node" aria-hidden="true"></span>
                                    <span class="timeline-sk timeline-sk--time timeline-sk--end"></span>
                                </div>
                                <div class="timeline-skeleton-card">
                                    <div class="timeline-sk timeline-sk--chip"></div>
                                    <div class="timeline-sk timeline-sk--title"></div>
                                    <div class="timeline-sk timeline-sk--body"></div>
                                </div>
                            </div>
                        }
                        <span class="sr-only">Generating schedule blocks, please wait…</span>
                    </div>
                }
                else if (sessions.Count == 0)
                {
                    <div class="rounded-xl border border-dashed border-border bg-muted/20 p-8 text-center">
                        <p class="font-medium">No timeline blocks yet.</p>
                        <p class="mt-1 text-sm text-muted-foreground">
                            Add sessions manually or ask Planner to draft the first pass.
                        </p>
                    </div>
                }
                else
                {
                    <div class="@GetTimelineClass()" role="list" aria-label="Run of show timeline">
                        @foreach (var session in OrderedSessions)
                        {
                            var reasoning = GetTimelineReasoning(session);
                            var intelligence = GetTimelineIntelligence(session);
                            <article @key="session.Id" data-test="session-card" class="@GetTimelineItemClass(session)" style="@GetTimelineItemStyle(session)" role="listitem">
                                <div class="event-flow-time-axis" aria-label="@GetTimelineTimeLabel(session)">
                                    <span class="event-flow-time-start">@session.StartTime</span>
                                    <span class="@GetTimelineNodeClass(session)" aria-hidden="true"></span>
                                    <span class="event-flow-time-end">@session.EndTime</span>
                                </div>
                                <div class="@GetTimelineCardShellClass(session)">
                                    <BbCard @key="session.Id" Class="p-4 border border-border bg-card shadow-sm">
                                        @if (session.IsEditing)
                                        {
                                            <div class="space-y-3">
                                                <BbInput @bind-Value="session.Title" Placeholder="Session title" />
                                                <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                                                    <BbInput @bind-Value="session.Speaker" Placeholder="Speaker name" />
                                                    <BbInput @bind-Value="session.Format" Placeholder="Format tag" />
                                                </div>
                                                <div class="flex flex-wrap gap-3">
                                                    <input type="time" value="@session.StartTime"
                                                           @onchange="@(e => session.StartTime = e.Value?.ToString() ?? "09:00")"
                                                           class="flex h-9 rounded-md border border-input bg-transparent px-3 py-1 text-sm" />
                                                    <input type="time" value="@session.EndTime"
                                                           @onchange="@(e => session.EndTime = e.Value?.ToString() ?? "09:30")"
                                                           class="flex h-9 rounded-md border border-input bg-transparent px-3 py-1 text-sm" />
                                                </div>
                                                <BbTextarea @bind-Value="session.Description" Placeholder="Session description" />
                                                <div class="flex gap-2">
                                                    <BbButton Variant="ButtonVariant.Default" Size="ButtonSize.Small"
                                                              OnClick="@(() => session.IsEditing = false)">
                                                        Save
                                                    </BbButton>
                                                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small"
                                                              OnClick="@(() => CancelEdit(session))">
                                                        Cancel
                                                    </BbButton>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                                                <div class="min-w-0">
                                                    <div class="mb-2 flex flex-wrap items-center gap-2">
                                                        <span class="font-mono text-xs text-muted-foreground">@session.Order.ToString("00", System.Globalization.CultureInfo.InvariantCulture)</span>
                                                        <span class="@GetTimelineTypeChipClass(session)">@GetFormatDisplay(session.Format)</span>
                                                        <span class="@GetReasoningIndicatorClass(reasoning)">✦ @reasoning.Indicator</span>
                                                        @if (GetDiffTagText(session) is { } diffTag)
                                                        {
                                                            <span class="@GetDiffTagClass(session)" data-test="timeline-diff-tag">@diffTag</span>
                                                        }
                                                        @if (IsFocusedReviewBlock(session))
                                                        {
                                                            <span class="event-flow-focus-chip">Review focus</span>
                                                        }
                                                    </div>
                                                    <h3 class="text-lg font-semibold leading-tight">@session.Title</h3>
                                                    @if (!string.IsNullOrWhiteSpace(session.Speaker))
                                                    {
                                                        <p class="mt-1 text-sm text-muted-foreground">@session.Speaker</p>
                                                    }
                                                    @if (!string.IsNullOrWhiteSpace(session.Description))
                                                    {
                                                        <p class="mt-3 text-sm">
                                                            @TruncateText(session.Description, 150)
                                                        </p>
                                                    }
                                                    @if (_showAgentTimeline)
                                                    {
                                                        <div class="agent-timeline-overlay" data-test="agent-timeline-overlay">
                                                            <div class="agent-timeline-energy">
                                                                <span class="@GetEnergyMeterClass(intelligence.EnergyLevel)" aria-hidden="true"></span>
                                                                <div>
                                                                    <span class="agent-timeline-label">Energy</span>
                                                                    <p>@intelligence.EnergyLabel</p>
                                                                </div>
                                                            </div>
                                                            <div class="agent-timeline-intel-grid">
                                                                <div>
                                                                    <span class="agent-timeline-label">Track balance</span>
                                                                    <p>@intelligence.TrackBalance</p>
                                                                </div>
                                                                <div>
                                                                    <span class="agent-timeline-label">Pacing decision</span>
                                                                    <p>@intelligence.PacingDecision</p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    }
                                                    <details class="event-flow-reasoning" data-test="timeline-block-reasoning">
                                                        <summary>
                                                            <span class="event-flow-reasoning-summary-icon" aria-hidden="true">🧠</span>
                                                            Agent reasoning
                                                        </summary>
                                                        <div class="event-flow-reasoning-body">
                                                            <div>
                                                                <span class="event-flow-reasoning-label">Flow role</span>
                                                                <p>@reasoning.FlowRole</p>
                                                            </div>
                                                            <div>
                                                                <span class="event-flow-reasoning-label">Why here</span>
                                                                <p>@reasoning.WhyPlaced</p>
                                                            </div>
                                                        </div>
                                                    </details>
                                                </div>
                                                <div class="session-actions flex shrink-0 flex-wrap gap-1">
                                                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small"
                                                              OnClick="@(() => StartEdit(session))">
                                                        ✏️
                                                    </BbButton>
                                                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small"
                                                              OnClick="@(() => MoveUp(session))"
                                                              Disabled="@(session.Order <= 1)">
                                                        ▲
                                                    </BbButton>
                                                    <BbButton Variant="ButtonVariant.Ghost" Size="ButtonSize.Small"
                                                              OnClick="@(() => MoveDown(session))"
                                                              Disabled="@(session.Order >= sessions.Count)">
                                                        ▼
                                                    </BbButton>
                                                    <BbButton Variant="ButtonVariant.Destructive" Size="ButtonSize.Small"
                                                              OnClick="@(() => DeleteSession(session))">
                                                        🗑️
                                                    </BbButton>
                                                </div>
                                            </div>
                                        }
                                    </BbCard>
                                </div>
                            </article>
                        }
                    </div>
                }

                @if (showAddForm)
                {
                    <BbCard Class="mt-5 p-4 border border-border bg-muted/20">
                        <h3 class="mb-3 font-semibold">Add Timeline Block</h3>
                        <div class="space-y-3">
                            <BbInput @bind-Value="newSession.Title" Placeholder="Session title (required)" />
                            <div class="grid grid-cols-1 gap-3 md:grid-cols-2">
                                <BbInput @bind-Value="newSession.Speaker" Placeholder="Speaker name" />
                                <BbInput @bind-Value="newSession.Format" Placeholder="Format tag" />
                            </div>
                            <div class="flex flex-wrap gap-3">
                                <input type="time" value="@newSession.StartTime"
                                       @onchange="@(e => newSession.StartTime = e.Value?.ToString() ?? "09:00")"
                                       class="flex h-9 rounded-md border border-input bg-transparent px-3 py-1 text-sm" />
                                <input type="time" value="@newSession.EndTime"
                                       @onchange="@(e => newSession.EndTime = e.Value?.ToString() ?? "09:30")"
                                       class="flex h-9 rounded-md border border-input bg-transparent px-3 py-1 text-sm" />
                            </div>
                            <BbTextarea @bind-Value="newSession.Description" Placeholder="Session description" />
                            <div class="flex gap-2">
                                <BbButton Variant="ButtonVariant.Default"
                                          OnClick="AddSession"
                                          Disabled="@string.IsNullOrWhiteSpace(newSession.Title)">
                                    Add
                                </BbButton>
                                <BbButton Variant="ButtonVariant.Ghost"
                                          OnClick="@(() => showAddForm = false)">
                                    Cancel
                                </BbButton>
                            </div>
                        </div>
                    </BbCard>
                }
            </BbCard>

            @if (!string.IsNullOrWhiteSpace(_plannerMarkdown))
            {
                <BbCard Class="p-5 border border-border bg-card">
                    <div class="review-card-header mb-4">
                        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-muted-foreground">Human Review</p>
                        <h3 class="mt-1 font-semibold">Review Required</h3>
                        <p class="mt-1 text-sm text-muted-foreground">
                            Review the Planner's reasoning, edit the draft if needed, then approve.
                        </p>
                    </div>

                    @* ── Structured Insight Deck ── *@
                    @if (ActiveAgendaJson is not null)
                    {
                        <div class="review-insight-deck" data-test="review-insights">
                            <div class="review-insight-deck-grid">

                                @* Objectives — blue *@
                                @if (GetObjectives().Any())
                                {
                                    <div class="review-insight-card review-insight-card--objectives" data-test="review-insight-objectives">
                                        <div class="review-insight-card-header">
                                            <span class="review-insight-icon" aria-hidden="true">🎯</span>
                                            <h4 class="review-insight-title">Objectives</h4>
                                            <span class="review-insight-count">@GetObjectives().Count()</span>
                                        </div>
                                        <ul class="review-insight-list">
                                            @foreach (var objective in GetObjectives())
                                            {
                                                <li>@objective</li>
                                            }
                                        </ul>
                                    </div>
                                }

                                @* Constraints — yellow/warning *@
                                @if (GetConstraints().Any())
                                {
                                    <div class="review-insight-card review-insight-card--constraints" data-test="review-insight-constraints">
                                        <div class="review-insight-card-header">
                                            <span class="review-insight-icon" aria-hidden="true">⚠️</span>
                                            <h4 class="review-insight-title">Constraints</h4>
                                            <span class="review-insight-count">@GetConstraints().Count()</span>
                                        </div>
                                        <ul class="review-insight-list">
                                            @foreach (var constraint in GetConstraints())
                                            {
                                                <li>@constraint</li>
                                            }
                                        </ul>
                                    </div>
                                }

                                @* Risks — red *@
                                @if (GetRiskItems().Any())
                                {
                                    <div class="review-insight-card review-insight-card--risks" data-test="review-insight-risks">
                                        <div class="review-insight-card-header">
                                            <span class="review-insight-icon" aria-hidden="true">⚡</span>
                                            <h4 class="review-insight-title">Risks</h4>
                                            <span class="review-insight-count">@GetRiskItems().Count()</span>
                                        </div>
                                        <div class="review-insight-risks-list">
                                            @foreach (var risk in GetRiskItems())
                                            {
                                                <div class="review-insight-risk-item">
                                                    <p class="review-insight-risk-label">@risk.Risk</p>
                                                    <p class="review-insight-risk-mitigation">↳ @risk.Mitigation</p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }

                                @* Next Actions — green/neutral checklist *@
                                @if (GetNextActions().Any())
                                {
                                    <div class="review-insight-card review-insight-card--next-actions" data-test="review-insight-next-actions">
                                        <div class="review-insight-card-header">
                                            <span class="review-insight-icon" aria-hidden="true">☑</span>
                                            <h4 class="review-insight-title">Next Actions</h4>
                                            <span class="review-insight-count">@GetNextActions().Count()</span>
                                        </div>
                                        <ul class="review-insight-checklist">
                                            @foreach (var action in GetNextActions())
                                            {
                                                <li>
                                                    <span class="review-insight-action-owner">@action.Owner</span>
                                                    @action.Action
                                                </li>
                                            }
                                        </ul>
                                    </div>
                                }
                            </div>

                            @* Raw Schema — collapsible, hidden by default *@
                            <div class="mt-3">
                                <button class="review-raw-schema-toggle"
                                        data-test="review-raw-schema-toggle"
                                        @onclick="ToggleRawSchema"
                                        type="button"
                                        aria-expanded="@_showRawSchema.ToString().ToLowerInvariant()">
                                    <span aria-hidden="true">@(_showRawSchema ? "▲" : "▼")</span>
                                    @(_showRawSchema ? "Hide Raw Schema" : "View Raw Schema")
                                </button>
                                @if (_showRawSchema)
                                {
                                    <pre class="review-raw-schema-viewer" data-test="review-raw-schema-viewer" aria-label="Raw JSON schema">@GetRawSchemaJson()</pre>
                                }
                            </div>
                        </div>
                    }

                    <div data-test="planner-markdown-editor" class="mt-5">
                        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.18em] text-muted-foreground">Edit Draft</p>
                        <BbTextarea @bind-Value="_plannerMarkdown" Rows="10" />
                    </div>

                    <div class="mt-3 flex flex-wrap gap-2">
                        <div data-test="approve-btn">
                            <BbButton Variant="ButtonVariant.Default"
                                      OnClick="ApproveScheduleAsync"
                                      Disabled="@(_activeCycle?.ActiveDraft is null || isCyclePublished)">
                                ✅ Approve
                            </BbButton>
                        </div>
                        <BbButton Variant="ButtonVariant.Ghost"
                                  OnClick="LoadPlanningCycleAsync"
                                  Disabled="@isCyclePublished">
                            ↺ Reload Active Cycle
                        </BbButton>
                    </div>
                </BbCard>
            }
        </main>

        @* ── Right Panel: Planner reasoning, no raw JSON ── *@
        <aside class="xl:col-span-3 space-y-4">
            <BbCard Class="p-4 border border-border bg-card agent-reasoning-card">
                <div class="agent-reasoning-header mb-4">
                    <p class="text-xs font-semibold uppercase tracking-[0.22em] text-muted-foreground">Agent Reasoning</p>
                    <h2 class="mt-1 text-lg font-semibold">Planner Insights</h2>
                </div>

                @if (!HasPlannerInsights)
                {
                    <p class="text-sm text-muted-foreground">
                        Insights appear here after Planner drafts an agenda. No raw schema view is shown.
                    </p>
                }
                else
                {
                    <div class="space-y-4">
                        <section>
                            <h3 class="mb-2 text-sm font-semibold">Constraints</h3>
                            <ul class="space-y-2">
                                @foreach (var constraint in GetConstraints())
                                {
                                    <li class="rounded-lg border border-border bg-muted/30 p-3 text-sm">@constraint</li>
                                }
                            </ul>
                        </section>

                        <section>
                            <h3 class="mb-2 text-sm font-semibold">Rationale</h3>
                            <div class="space-y-2">
                                @foreach (var tradeoff in GetRationaleItems())
                                {
                                    <div class="rounded-lg border border-border bg-muted/30 p-3 text-sm">@tradeoff</div>
                                }
                            </div>
                        </section>

                        <section>
                            <h3 class="mb-2 text-sm font-semibold">Risks & Mitigations</h3>
                            <div class="space-y-2">
                                @foreach (var risk in GetRiskItems())
                                {
                                    <div class="rounded-lg border border-border bg-muted/30 p-3">
                                        <p class="text-sm font-medium">@risk.Risk</p>
                                        <p class="mt-1 text-sm text-muted-foreground">@risk.Mitigation</p>
                                    </div>
                                }
                            </div>
                        </section>
                    </div>
                }
            </BbCard>

            <BbCard Class="p-4 border border-border bg-card">
                <h3 class="mb-3 font-semibold">Publish Controls</h3>
                <div class="flex flex-col gap-2">
                    <div data-test="publish-btn">
                        <BbButton Variant="ButtonVariant.Outline"
                                  OnClick="PublishScheduleAsync"
                                  Disabled="@(!CanPublish)">
                            📢 Publish Schedule
                        </BbButton>
                    </div>
                    <div data-test="start-new-cycle-btn">
                        <BbButton Variant="ButtonVariant.Ghost"
                                  OnClick="StartNewCycleAsync"
                                  Disabled="@(!isCyclePublished)">
                            🔁 Start New Cycle
                        </BbButton>
                    </div>
                </div>
                <p class="mt-3 text-sm text-muted-foreground">
                    Approval opens publish. Publish locks the cycle.
                </p>
            </BbCard>
        </aside>
    </div>
</div>

@code {
    [Parameter] public Guid EventId { get; set; }
    [Parameter] public string? Slug { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private string eventTitle = "Event";
    private string? _resolvedHashtag;
    private ScheduleStatus agendaStatus = ScheduleStatus.Draft;
    private List<SessionViewModel> sessions = [];
    private SessionViewModel newSession = new();
    private bool showAddForm;
    private bool isAiDrafting;
    private string? statusMessage;
    private string _refineConstraints = string.Empty;
    private int? _targetDurationMinutes;
    private readonly List<ConsoleMessage> _consoleMessages = [];
    private PlanningCycleDto? _activeCycle;
    private string _plannerMarkdown = string.Empty;
    private readonly Dictionary<Guid, SessionViewModel> editSnapshots = new();
    private bool _showRawSchema;
    private HashSet<Guid> _newlyGeneratedBlockIds = [];
    private readonly HashSet<Guid> _updatedGeneratedBlockIds = [];
    private int _activePlannerReasoningStep = -1;
    private string? _plannerLiveStatus;
    private string? _applyingSteeringLabel;
    private bool _showAgentTimeline;
    private bool isCyclePublished => _activeCycle?.Status == "Published";
    private bool CanPublish => _activeCycle?.Status == "ReadyToPublish" && _activeCycle.ActiveDraft is not null;
    private PlanningAgendaJsonDto? ActiveAgendaJson => _activeCycle?.ActiveDraft?.AgendaJson;
    private IEnumerable<SessionViewModel> OrderedSessions => sessions.OrderBy(s => s.Order);
    private SessionViewModel? FocusedReviewSession =>
        OrderedSessions.FirstOrDefault(session => NormalizeSessionFormat(session.Format) != "break")
        ?? OrderedSessions.FirstOrDefault();
    private bool HasPlannerInsights =>
        ActiveAgendaJson is not null &&
        (GetConstraints().Any() || GetRationaleItems().Any() || GetRiskItems().Any());

    protected override async Task OnParametersSetAsync()
    {
        // When navigating to /events/{hashtag}, resolve the event via the slug API
        if (Slug is not null && EventId == Guid.Empty)
        {
            try
            {
                var dto = await EventApi.GetByHashtagAsync(Slug);
                EventId = dto.Id;
                eventTitle = dto.Title;
                _resolvedHashtag = dto.Hashtag;
            }
            catch
            {
                // Event not found; leave defaults so page still renders
            }
        }

        if (EventId != Guid.Empty)
        {
            try
            {
                var evt = await EventApi.GetByIdAsync(EventId);
                eventTitle = evt.Title;
            }
            catch (Exception)
            {
                // Keep default title if event read fails.
            }

            await LoadPlanningCycleAsync();
        }
    }

    // ── View-local enum (mirrors Hackmum.Bethuya.Core.Enums.AgendaStatus) ──
    private enum ScheduleStatus
    {
        Draft,
        ProposedByAgent,
        ApprovedByHuman,
        Published,
        Archived
    }

    private sealed class SessionViewModel
    {
        public Guid Id { get; set; } = Guid.NewGuid();
        public string BlockId { get; set; } = "";
        public string Title { get; set; } = "";
        public string Speaker { get; set; } = "";
        public string StartTime { get; set; } = "09:00";
        public string EndTime { get; set; } = "09:30";
        public string Description { get; set; } = "";
        public string Format { get; set; } = "session";
        public int Order { get; set; }
        public bool IsEditing { get; set; }
    }

    private static readonly string[] PlannerReasoningSteps =
    [
        "Analyzing constraints...",
        "Balancing session types...",
        "Optimizing flow for engagement..."
    ];

    private sealed class ConsoleMessage(string role, string text, bool isStreaming = false)
    {
        public string Role { get; } = role;
        public string Text { get; set; } = text;
        public bool IsStreaming { get; set; } = isStreaming;
    }

    private sealed record TimelineReasoning(string FlowRole, string Indicator, string IndicatorKey, string WhyPlaced);

    private sealed record TimelineIntelligence(
        int EnergyLevel,
        string EnergyLabel,
        string TrackBalance,
        string PacingDecision);

    private sealed record SessionSnapshot(
        Guid Id,
        string StableKey,
        string Title,
        string Speaker,
        string StartTime,
        string EndTime,
        string Description,
        string Format,
        int Order)
    {
        public static SessionSnapshot From(SessionViewModel session) => new(
            session.Id,
            GetBlockStableKey(session),
            NormalizeDiffValue(session.Title),
            NormalizeDiffValue(session.Speaker),
            NormalizeDiffValue(session.StartTime),
            NormalizeDiffValue(session.EndTime),
            NormalizeDiffValue(session.Description),
            NormalizeDiffValue(session.Format),
            session.Order);

        public bool Matches(PlanningAgendaBlockDto block, int order) =>
            string.Equals(Title, NormalizeDiffValue(block.Title), StringComparison.Ordinal) &&
            string.Equals(Speaker, NormalizeDiffValue(block.Speakers.FirstOrDefault()?.Name), StringComparison.Ordinal) &&
            string.Equals(StartTime, NormalizeDiffValue(block.Start), StringComparison.Ordinal) &&
            string.Equals(EndTime, NormalizeDiffValue(block.End), StringComparison.Ordinal) &&
            string.Equals(Description, NormalizeDiffValue(block.Description), StringComparison.Ordinal) &&
            string.Equals(Format, NormalizeDiffValue(block.Format), StringComparison.Ordinal) &&
            Order == order;
    }

    // ── Badge mapping ──

    private static BadgeVariant GetStatusBadgeVariant(ScheduleStatus status) => status switch
    {
        ScheduleStatus.Draft => BadgeVariant.Outline,
        ScheduleStatus.ProposedByAgent => BadgeVariant.Secondary,
        ScheduleStatus.ApprovedByHuman => BadgeVariant.Default,
        ScheduleStatus.Published => BadgeVariant.Default,
        ScheduleStatus.Archived => BadgeVariant.Destructive,
        _ => BadgeVariant.Outline
    };

    private static string GetStatusDisplayText(ScheduleStatus status) => status switch
    {
        ScheduleStatus.Published => "✅ Published",
        ScheduleStatus.ProposedByAgent => "Proposed by Agent",
        ScheduleStatus.ApprovedByHuman => "Approved",
        _ => status.ToString()
    };

    private static string TruncateText(string text, int maxLength) =>
        text.Length > maxLength ? string.Concat(text.AsSpan(0, maxLength), "…") : text;

    private static string GetFormatDisplay(string? format) =>
        string.IsNullOrWhiteSpace(format) ? "session" : format.Trim();

    private bool IsFocusedReviewBlock(SessionViewModel session) =>
        FocusedReviewSession?.Id == session.Id;

    private static string NormalizeSessionFormat(string? format)
    {
        if (string.IsNullOrWhiteSpace(format))
        {
            return "other";
        }

        return format.Trim().ToUpperInvariant() switch
        {
            "TALK" => "talk",
            "WORKSHOP" => "workshop",
            "BREAK" => "break",
            _ => "other"
        };
    }

    private static string GetTimelineItemClass(SessionViewModel session) =>
        $"event-flow-item event-flow-item--{NormalizeSessionFormat(session.Format)}";

    private string GetTimelineClass()
    {
        var updatingClass = isAiDrafting ? " timeline-is-updating" : string.Empty;
        var agentClass = _showAgentTimeline ? " agent-timeline-visible" : string.Empty;
        return $"event-flow-timeline{updatingClass}{agentClass}";
    }

    private static string GetTimelineItemStyle(SessionViewModel session)
    {
        var duration = GetSessionDurationMinutes(session);
        var scaledHeight = Math.Clamp(6.8 + (duration / 30d * 1.4), 7.4, 14.5);
        var scaledGap = Math.Clamp(0.72 + (duration / 90d * 0.45), 0.85, 1.55);
        return string.Create(
            System.Globalization.CultureInfo.InvariantCulture,
            $"--event-duration-min:{duration};--event-block-min:{scaledHeight:0.##}rem;--event-flow-gap:{scaledGap:0.##}rem;");
    }

    private string GetTimelineCardShellClass(SessionViewModel session)
    {
        var focusClass = IsFocusedReviewBlock(session) ? " is-focus" : string.Empty;
        var newClass = _newlyGeneratedBlockIds.Contains(session.Id) ? " is-new-block" : string.Empty;
        var updatedClass = _updatedGeneratedBlockIds.Contains(session.Id) ? " is-updated-block" : string.Empty;
        return $"event-flow-card-shell event-flow-card-shell--{NormalizeSessionFormat(session.Format)}{focusClass}{newClass}{updatedClass}";
    }

    private static string GetTimelineNodeClass(SessionViewModel session) =>
        $"event-flow-node event-flow-node--{NormalizeSessionFormat(session.Format)}";

    private static string GetTimelineTypeChipClass(SessionViewModel session) =>
        $"event-flow-type-chip event-flow-type-chip--{NormalizeSessionFormat(session.Format)}";

    private static string GetTimelineTimeLabel(SessionViewModel session) =>
        $"{session.Title}, {session.StartTime} to {session.EndTime}";

    private static int GetSessionDurationMinutes(SessionViewModel session)
    {
        if (!TimeOnly.TryParse(session.StartTime, System.Globalization.CultureInfo.InvariantCulture, out var start) ||
            !TimeOnly.TryParse(session.EndTime, System.Globalization.CultureInfo.InvariantCulture, out var end))
        {
            return 30;
        }

        var duration = end - start;
        if (duration.TotalMinutes <= 0)
        {
            duration = duration.Add(TimeSpan.FromHours(24));
        }

        return Math.Clamp((int)Math.Round(duration.TotalMinutes), 15, 240);
    }

    private static string GetReasoningIndicatorClass(TimelineReasoning reasoning) =>
        $"event-flow-reasoning-chip event-flow-reasoning-chip--{reasoning.IndicatorKey}";

    private static string GetEnergyMeterClass(int energyLevel) =>
        $"agent-timeline-energy-meter agent-timeline-energy-meter--{energyLevel}";

    private void ToggleAgentTimeline() => _showAgentTimeline = !_showAgentTimeline;

    private TimelineIntelligence GetTimelineIntelligence(SessionViewModel session)
    {
        var ordered = OrderedSessions.ToList();
        var index = ordered.FindIndex(item => item.Id == session.Id);
        var safeIndex = index < 0 ? 0 : index;
        var lastIndex = Math.Max(ordered.Count - 1, 0);
        var format = NormalizeSessionFormat(session.Format);
        var duration = GetSessionDurationMinutes(session);

        if (format == "break")
        {
            return new(
                1,
                "Low - recovery",
                "Neutral reset between content tracks",
                "Cool-down beat protects attention before the next lift.");
        }

        if (safeIndex == 0)
        {
            return new(
                2,
                "Rising - warm-up",
                "Foundation block before track divergence",
                "Starts with shared context before asking for deeper attention.");
        }

        if (safeIndex == lastIndex)
        {
            return new(
                1,
                "Cool down",
                "Final synthesis after mixed formats",
                "Ends with lower intensity so attendees leave with a clear takeaway.");
        }

        if (format == "workshop")
        {
            return new(
                3,
                "Peak - active",
                "Hands-on block balances talk-heavy stretches",
                duration >= 60
                    ? "Longer active segment is placed where energy can sustain practice."
                    : "Compact practice slot keeps momentum without exhausting the room.");
        }

        return new(
            2,
            "Steady - concept",
            "Talk block bridges adjacent formats",
            "Keeps information density controlled before the flow shifts again.");
    }

    private string? GetDiffTagText(SessionViewModel session)
    {
        if (_newlyGeneratedBlockIds.Contains(session.Id))
        {
            return "New";
        }

        return _updatedGeneratedBlockIds.Contains(session.Id) ? "Updated" : null;
    }

    private string GetDiffTagClass(SessionViewModel session)
    {
        var modifier = _newlyGeneratedBlockIds.Contains(session.Id) ? "new" : "updated";
        return $"event-flow-diff-chip event-flow-diff-chip--{modifier}";
    }

    private TimelineReasoning GetTimelineReasoning(SessionViewModel session)
    {
        var ordered = OrderedSessions.ToList();
        var index = ordered.FindIndex(item => item.Id == session.Id);
        var safeIndex = index < 0 ? 0 : index;
        var format = NormalizeSessionFormat(session.Format);
        var previousFormat = safeIndex > 0 ? NormalizeSessionFormat(ordered[safeIndex - 1].Format) : string.Empty;
        var title = session.Title ?? string.Empty;

        if (format == "break")
        {
            return new("Recovery beat", "balanced", "balanced",
                "Creates breathing room between higher-intensity sessions so attendees can reset before the next block.");
        }

        if (format == "workshop" && previousFormat == "talk")
        {
            return new("Hands-on continuity", "optimized", "optimized",
                "Workshop follows a concept talk for continuity, turning fresh context into practice while attention is still high.");
        }

        if (safeIndex == 0)
        {
            var why = title.Contains("keynote", StringComparison.OrdinalIgnoreCase)
                ? "Placed keynote early to maximize attendance and anchor the event narrative before smaller sessions branch out."
                : "Placed early as a warm-up so the room gets shared context before deeper or more interactive blocks.";
            return new("Warm-up", "optimized", "optimized", why);
        }

        if (safeIndex >= Math.Max(ordered.Count - 1, 0))
        {
            return new("Wind-down", "balanced", "balanced",
                "Positioned near the close to lower cognitive load and leave attendees with a clear final takeaway.");
        }

        if (format == "workshop")
        {
            return new("Peak engagement", "optimized", "optimized",
                "Scheduled in the middle of the flow when attendees have enough context and energy for active participation.");
        }

        return new("Flow bridge", "balanced", "balanced",
            "Placed here to balance pacing between adjacent formats and keep the agenda from feeling repetitive.");
    }

    private string GetUserThreadMessage() => _activeCycle is null
        ? "Ready to request an AI schedule draft."
        : _activeCycle.Status switch
        {
            "ReadyToPublish" => "Approved the Planner draft for publish.",
            "Published" => "Published the approved schedule.",
            _ when _activeCycle.ActiveDraft is not null => "Requested a draft and is reviewing edits.",
            _ => "Started a planning cycle."
        };

    private string GetPlannerThreadMessage() => _activeCycle is null
        ? "Waiting for a cycle."
        : _activeCycle.Status switch
        {
            "Published" => "Cycle closed; future revisions need a fresh conversation.",
            "ReadyToPublish" => "Draft reconciled with human edits.",
            _ when isAiDrafting => "Drafting a timeline and reasoning pack…",
            _ when _activeCycle.ActiveDraft is not null => "Returned agenda blocks, constraints, rationale, and risks.",
            _ => "Cycle ready; no draft has been generated yet."
        };

    private string GetStatusDotClass() => isAiDrafting
        ? "agent-console-status-dot agent-console-status-dot--active"
        : isCyclePublished
            ? "agent-console-status-dot agent-console-status-dot--locked"
            : "agent-console-status-dot";

    // ── Agent Session status bar helpers ──

    private string GetShortCycleId() =>
        _activeCycle is null
            ? "no cycle"
            : _activeCycle.CycleId.ToString("N")[..8];

    private string GetShortConversationId()
    {
        var convId = _activeCycle?.ConversationId;
        if (string.IsNullOrWhiteSpace(convId))
            return "—";
        return convId.Length <= 14 ? convId : string.Concat(convId.AsSpan(0, 14), "…");
    }

    private string GetAgentStatusText()
    {
        if (isAiDrafting) return "generating";
        if (isCyclePublished) return "locked";
        if (_activeCycle?.ActiveDraft is not null) return "completed";
        return "idle";
    }

    private string GetAgentStatusPillClass() => GetAgentStatusText() switch
    {
        "generating" => "agent-session-pill--generating",
        "locked" => "agent-session-pill--locked",
        "completed" => "agent-session-pill--completed",
        _ => "agent-session-pill--idle"
    };

    private void InitConsoleMessages()
    {
        _consoleMessages.Clear();
        if (_activeCycle is null)
        {
            _consoleMessages.Add(new("User", "Ready to request an AI schedule draft."));
            _consoleMessages.Add(new("Planner", "Waiting for a cycle to begin."));
            return;
        }

        _consoleMessages.Add(new("User", GetUserThreadMessage()));
        _consoleMessages.Add(new("Planner", GetPlannerThreadMessage()));
        if (isCyclePublished)
            _consoleMessages.Add(new("Planner", "Cycle closed. Start a new cycle for post-publish changes."));
    }

    private void UpdateTargetDuration(ChangeEventArgs e)
    {
        _targetDurationMinutes = int.TryParse(e.Value?.ToString(), out var v) ? v : null;
    }

    private async Task ApplyPromptChipAsync(string chipLabel, string constraintText)
    {
        _refineConstraints = string.IsNullOrWhiteSpace(_refineConstraints)
            ? constraintText
            : $"{_refineConstraints.TrimEnd(';', ' ')}; {constraintText}";
        _applyingSteeringLabel = chipLabel;
        _consoleMessages.Add(new("User", $"Refine schedule: {chipLabel}"));
        await DraftWithAiAsync(constraintText, chipLabel);
    }

    private Task ChipShortenEventAsync() =>
        ApplyPromptChipAsync("Shorten event", "Shorten the event — reduce total duration without losing key talks.");

    private Task ChipAddNetworkingAsync() =>
        ApplyPromptChipAsync("Add networking block", "Add a dedicated networking block to the agenda and rebalance adjacent sessions around it.");

    private Task ChipRebalanceAsync() =>
        ApplyPromptChipAsync("Rebalance sessions", "Rebalance session durations so no single block dominates.");

    private string GetPlannerReasoningStepClass(int stepIndex)
    {
        var stateClass = stepIndex < _activePlannerReasoningStep
            ? "is-complete"
            : stepIndex == _activePlannerReasoningStep
                ? "is-active"
                : "is-pending";
        return $"agent-console-reasoning-step {stateClass}";
    }

    private async Task TypePlannerMessageAsync(string text)
    {
        var msg = new ConsoleMessage("Planner", string.Empty, isStreaming: true);
        _consoleMessages.Add(msg);

        for (var i = 1; i <= text.Length; i++)
        {
            msg.Text = text[..i];
            await InvokeAsync(StateHasChanged);
            await Task.Delay(18);
        }

        msg.IsStreaming = false;
        await InvokeAsync(StateHasChanged);
    }

    private IEnumerable<string> GetConstraints() =>
        ActiveAgendaJson?.Constraints.Where(item => !string.IsNullOrWhiteSpace(item)) ?? [];

    private IEnumerable<string> GetObjectives() =>
        ActiveAgendaJson?.Objectives.Where(item => !string.IsNullOrWhiteSpace(item)) ?? [];

    private IEnumerable<PlanningAgendaActionDto> GetNextActions() =>
        ActiveAgendaJson?.NextActions.Items.Where(item => !string.IsNullOrWhiteSpace(item.Action)) ?? [];

    private void ToggleRawSchema() => _showRawSchema = !_showRawSchema;

    private string GetRawSchemaJson()
    {
        if (ActiveAgendaJson is null)
        {
            return string.Empty;
        }

        return System.Text.Json.JsonSerializer.Serialize(
            ActiveAgendaJson,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
    }

    private IEnumerable<string> GetRationaleItems()
    {
        if (ActiveAgendaJson?.Rationale is null)
        {
            return [];
        }

        return ActiveAgendaJson.Rationale.KeyTradeoffs
            .Concat(ActiveAgendaJson.Rationale.InclusionNotes)
            .Where(item => !string.IsNullOrWhiteSpace(item));
    }

    private IEnumerable<PlanningAgendaRiskDto> GetRiskItems() =>
        ActiveAgendaJson?.Risks.Items.Where(item =>
            !string.IsNullOrWhiteSpace(item.Risk) ||
            !string.IsNullOrWhiteSpace(item.Mitigation)) ?? [];

    // ── Session CRUD ──

    private void AddSession()
    {
        if (string.IsNullOrWhiteSpace(newSession.Title))
            return;

        newSession.Order = sessions.Count + 1;
        sessions.Add(newSession);
        newSession = new SessionViewModel();
        showAddForm = false;
        statusMessage = null;
    }

    private void DeleteSession(SessionViewModel session)
    {
        ClearDiffState(session.Id);
        sessions.Remove(session);
        ReorderSessions();
        statusMessage = null;
    }

    private void MoveUp(SessionViewModel session)
    {
        ClearDiffState(session.Id);
        var other = sessions.Find(s => s.Order == session.Order - 1);
        if (other is null) return;
        other.Order++;
        session.Order--;
    }

    private void MoveDown(SessionViewModel session)
    {
        ClearDiffState(session.Id);
        var other = sessions.Find(s => s.Order == session.Order + 1);
        if (other is null) return;
        other.Order--;
        session.Order++;
    }

    private void ReorderSessions()
    {
        var ordered = sessions.OrderBy(s => s.Order).ToList();
        for (var i = 0; i < ordered.Count; i++)
            ordered[i].Order = i + 1;
    }

    // ── Inline editing with cancel support ──

    private void StartEdit(SessionViewModel session)
    {
        ClearDiffState(session.Id);
        editSnapshots[session.Id] = new SessionViewModel
        {
            Id = session.Id,
            BlockId = session.BlockId,
            Title = session.Title,
            Speaker = session.Speaker,
            StartTime = session.StartTime,
            EndTime = session.EndTime,
            Description = session.Description,
            Format = session.Format,
            Order = session.Order
        };
        session.IsEditing = true;
    }

    private void CancelEdit(SessionViewModel session)
    {
        if (editSnapshots.TryGetValue(session.Id, out var snapshot))
        {
            session.Title = snapshot.Title;
            session.Speaker = snapshot.Speaker;
            session.StartTime = snapshot.StartTime;
            session.EndTime = snapshot.EndTime;
            session.Description = snapshot.Description;
            session.Format = snapshot.Format;
            editSnapshots.Remove(session.Id);
        }
        session.IsEditing = false;
    }

    // ── AI Draft ──

    private async Task DraftWithAiAsync(string? steeringPrompt = null, string? steeringLabel = null)
    {
        if (EventId == Guid.Empty)
        {
            statusMessage = "Cannot draft schedule: event is not resolved.";
            return;
        }

        try
        {
            isAiDrafting = true;
            _activePlannerReasoningStep = -1;
            _plannerLiveStatus = "Planner is generating schedule";
            statusMessage = null;
            if (!string.IsNullOrWhiteSpace(steeringLabel))
            {
                _applyingSteeringLabel = steeringLabel;
            }

            if (string.IsNullOrWhiteSpace(steeringPrompt))
            {
                _consoleMessages.Add(new("User", "Draft a schedule from the current event context."));
            }
            StateHasChanged();
            var previousSnapshots = sessions
                .Select(SessionSnapshot.From)
                .GroupBy(snapshot => snapshot.StableKey, StringComparer.OrdinalIgnoreCase)
                .ToDictionary(group => group.Key, group => group.First(), StringComparer.OrdinalIgnoreCase);

            await Task.Delay(220);
            for (var stepIndex = 0; stepIndex < PlannerReasoningSteps.Length; stepIndex++)
            {
                _activePlannerReasoningStep = stepIndex;
                await TypePlannerMessageAsync(PlannerReasoningSteps[stepIndex]);
                await Task.Delay(280);
            }

            _activeCycle ??= await PlanningCycleApi.StartCycleAsync(EventId, new StartPlanningCycleDto());
            _activeCycle = await PlanningCycleApi.GenerateDraftAsync(
                _activeCycle.CycleId,
                new GeneratePlannerDraftDto(
                    WorkItemId: $"draft-{Guid.CreateVersion7():N}",
                    Constraints: BuildPlannerConstraints(steeringPrompt),
                    HumanEditedMarkdown: string.IsNullOrWhiteSpace(_plannerMarkdown) ? null : _plannerMarkdown,
                    RequestedBy: "organizer"));

            ApplyDraftToUi(_activeCycle.ActiveDraft, previousSnapshots);
            agendaStatus = ScheduleStatus.ProposedByAgent;
            await TypePlannerMessageAsync("Returned agenda blocks, constraints, rationale, and risks. Review and approve to publish.");
        }
        catch (Refit.ApiException apiEx)
        {
            statusMessage = $"Planner draft failed: {(int)apiEx.StatusCode} {apiEx.StatusCode}.";
            await TypePlannerMessageAsync($"Draft failed ({(int)apiEx.StatusCode}). Try again.");
        }
        finally
        {
            isAiDrafting = false;
            _activePlannerReasoningStep = -1;
            _plannerLiveStatus = null;
            _applyingSteeringLabel = null;
        }
    }

    private string? BuildPlannerConstraints(string? steeringPrompt)
    {
        var constraints = new List<string>();
        if (!string.IsNullOrWhiteSpace(_refineConstraints))
        {
            constraints.Add(_refineConstraints.Trim());
        }

        if (!string.IsNullOrWhiteSpace(steeringPrompt) &&
            !constraints.Any(item => string.Equals(item, steeringPrompt, StringComparison.OrdinalIgnoreCase)))
        {
            constraints.Add(steeringPrompt.Trim());
        }

        if (_targetDurationMinutes is { } targetDuration)
        {
            constraints.Add($"Target total duration: {targetDuration.ToString(System.Globalization.CultureInfo.InvariantCulture)} minutes.");
        }

        return constraints.Count == 0 ? null : string.Join(Environment.NewLine, constraints);
    }

    // ── Human-in-the-Loop actions ──

    private async Task ApproveScheduleAsync()
    {
        if (_activeCycle?.ActiveDraft is null || string.IsNullOrWhiteSpace(_plannerMarkdown))
        {
            statusMessage = "No planner draft is available to approve.";
            return;
        }

        try
        {
            _activeCycle = await PlanningCycleApi.ApproveDraftAsync(
                _activeCycle.CycleId,
                new ApprovePlannerDraftDto(
                    DraftId: _activeCycle.ActiveDraft.DraftId,
                    EditedMarkdown: _plannerMarkdown,
                    ApprovedBy: "organizer"));

            ApplyDraftToUi(_activeCycle.ActiveDraft);
            _newlyGeneratedBlockIds.Clear();
            _updatedGeneratedBlockIds.Clear();
            agendaStatus = ScheduleStatus.ApprovedByHuman;
            statusMessage = "✅ Draft approved and reconciled. Publish to finalize and close this cycle.";
            _consoleMessages.Add(new("User", "Approved the draft with edits."));
            _consoleMessages.Add(new("Planner", "Draft reconciled with human edits. Ready to publish."));
        }
        catch (Refit.ApiException apiEx)
        {
            statusMessage = $"Approval failed: {(int)apiEx.StatusCode} {apiEx.StatusCode}.";
        }
    }

    private async Task StartNewCycleAsync()
    {
        if (EventId == Guid.Empty)
        {
            return;
        }

        try
        {
            _activeCycle = await PlanningCycleApi.StartCycleAsync(EventId, new StartPlanningCycleDto(ForceNewCycle: true));
            _plannerMarkdown = string.Empty;
            sessions.Clear();
            _newlyGeneratedBlockIds.Clear();
            _updatedGeneratedBlockIds.Clear();
            agendaStatus = ScheduleStatus.Draft;
            statusMessage = "🔁 New planning cycle started with a new conversation thread.";
            _refineConstraints = string.Empty;
            _targetDurationMinutes = null;
            InitConsoleMessages();
        }
        catch (Refit.ApiException apiEx)
        {
            statusMessage = $"Cannot start new cycle: {(int)apiEx.StatusCode} {apiEx.StatusCode}.";
        }
    }

    // ── Quick Actions ──

    private async Task PublishScheduleAsync()
    {
        if (_activeCycle?.ActiveDraft is null)
        {
            statusMessage = "Nothing to publish.";
            return;
        }

        try
        {
            _ = await PlanningCycleApi.PublishAsync(
                _activeCycle.CycleId,
                new PublishPlanningCycleDto(
                    DraftId: _activeCycle.ActiveDraft.DraftId,
                    PublishedBy: "organizer"));
            _activeCycle = await PlanningCycleApi.GetActiveCycleAsync(EventId);
            agendaStatus = ScheduleStatus.Published;
            statusMessage = "📢 Schedule published. This cycle is now closed and refinement is blocked.";
            _consoleMessages.Add(new("User", "Published the approved schedule."));
            _consoleMessages.Add(new("Planner", "Cycle closed. Immutable snapshot stored."));
        }
        catch (Refit.ApiException apiEx)
        {
            statusMessage = $"Publish failed: {(int)apiEx.StatusCode} {apiEx.StatusCode}.";
        }
    }

    private void ClearAll()
    {
        sessions.Clear();
        _newlyGeneratedBlockIds.Clear();
        _updatedGeneratedBlockIds.Clear();
        agendaStatus = ScheduleStatus.Draft;
        statusMessage = null;
    }

    private async Task LoadPlanningCycleAsync()
    {
        try
        {
            _activeCycle = await PlanningCycleApi.GetActiveCycleAsync(EventId);
            ApplyDraftToUi(_activeCycle.ActiveDraft);

            agendaStatus = _activeCycle.Status switch
            {
                "Published" => ScheduleStatus.Published,
                "ReadyToPublish" => ScheduleStatus.ApprovedByHuman,
                _ when _activeCycle.ActiveDraft is not null => ScheduleStatus.ProposedByAgent,
                _ => ScheduleStatus.Draft
            };
        }
        catch (Refit.ApiException apiEx) when (apiEx.StatusCode == System.Net.HttpStatusCode.NotFound)
        {
            // No active cycle yet.
            _activeCycle = null;
        }

        InitConsoleMessages();
    }

    private void ApplyDraftToUi(
        PlannerDraftDto? draft,
        IReadOnlyDictionary<string, SessionSnapshot>? previousSnapshots = null)
    {
        _newlyGeneratedBlockIds.Clear();
        _updatedGeneratedBlockIds.Clear();

        if (draft is null)
        {
            _plannerMarkdown = string.Empty;
            return;
        }

        _plannerMarkdown = draft.HumanEditedMarkdown ?? draft.MarkdownAgenda;
        sessions = draft.AgendaJson.Agenda.Blocks
            .Select((block, index) =>
            {
                var stableKey = GetBlockStableKey(block);
                var order = index + 1;
                SessionSnapshot? snapshot = null;
                _ = previousSnapshots?.TryGetValue(stableKey, out snapshot);

                var session = new SessionViewModel
                {
                    Id = snapshot?.Id ?? Guid.NewGuid(),
                    BlockId = block.BlockId,
                    Title = block.Title,
                    Speaker = block.Speakers.FirstOrDefault()?.Name ?? string.Empty,
                    StartTime = block.Start,
                    EndTime = block.End,
                    Description = block.Description,
                    Format = block.Format,
                    Order = order
                };

                if (previousSnapshots is not null)
                {
                    if (snapshot is null)
                    {
                        _newlyGeneratedBlockIds.Add(session.Id);
                    }
                    else if (!snapshot.Matches(block, order))
                    {
                        _updatedGeneratedBlockIds.Add(session.Id);
                    }
                }

                return session;
            })
            .ToList();
    }

    private static string NormalizeDiffValue(string? value) => value?.Trim() ?? string.Empty;

    private static string GetBlockStableKey(SessionViewModel session)
    {
        if (!string.IsNullOrWhiteSpace(session.BlockId))
        {
            return session.BlockId.Trim();
        }

        return $"{NormalizeDiffValue(session.Title)}|{NormalizeDiffValue(session.StartTime)}";
    }

    private static string GetBlockStableKey(PlanningAgendaBlockDto block)
    {
        if (!string.IsNullOrWhiteSpace(block.BlockId))
        {
            return block.BlockId.Trim();
        }

        return $"{NormalizeDiffValue(block.Title)}|{NormalizeDiffValue(block.Start)}";
    }

    private void ClearDiffState(Guid sessionId)
    {
        _newlyGeneratedBlockIds.Remove(sessionId);
        _updatedGeneratedBlockIds.Remove(sessionId);
    }
}
