@page "/events/{EventId:guid}"

<PageTitle>Event Details — Bethuya</PageTitle>

<div class="container mx-auto p-4">
    <BbButton Variant="ButtonVariant.Ghost" OnClick="@(() => Navigation.NavigateTo("/events"))">
        ← Back to Events
    </BbButton>

    <BbCard Class="mt-4 p-6">
        <h1 class="text-2xl font-bold mb-2">Event Details</h1>
        <p class="text-muted-foreground mb-4">Event ID: @EventId</p>

        <div class="grid grid-cols-2 gap-6">
            <div>
                <h2 class="text-lg font-semibold mb-2">📋 Agenda</h2>
                <BbCard Class="p-4">
                    <p class="text-sm text-muted-foreground">
                        Use the <strong>Planner Agent</strong> to draft an agenda.
                    </p>
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="mt-2"
                              Disabled="true">
                        🤖 Invoke Planner
                    </BbButton>
                </BbCard>
            </div>

            <div>
                <h2 class="text-lg font-semibold mb-2">👥 Registrations</h2>
                <BbCard Class="p-4">
                    <p class="text-sm text-muted-foreground">
                        Manage attendee registrations and curation.
                    </p>
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="mt-2"
                              OnClick="@(() => Navigation.NavigateTo($"/events/{EventId}/registrations"))">
                        View Registrations
                    </BbButton>
                </BbCard>
            </div>

            <div>
                <h2 class="text-lg font-semibold mb-2">🎤 Live Facilitation</h2>
                <BbCard Class="p-4">
                    <p class="text-sm text-muted-foreground">
                        Get live prompts and Q&amp;A suggestions during the event.
                    </p>
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="mt-2"
                              Disabled="true">
                        🤖 Start Facilitator
                    </BbButton>
                </BbCard>
            </div>

            <div>
                <h2 class="text-lg font-semibold mb-2">📝 Post-Event Report</h2>
                <BbCard Class="p-4">
                    <p class="text-sm text-muted-foreground">
                        Generate a summary with highlights and action items.
                    </p>
                    <BbButton Variant="ButtonVariant.Outline" Size="ButtonSize.Small" Class="mt-2"
                              Disabled="true">
                        🤖 Draft Report
                    </BbButton>
                </BbCard>
            </div>
        </div>
    </BbCard>
</div>

@code {
    [Parameter] public Guid EventId { get; set; }
    [Inject] private NavigationManager Navigation { get; set; } = default!;
}
