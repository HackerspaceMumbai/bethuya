@page "/registration/aide"
@rendermode InteractiveServer
@layout OnboardingLayout
@attribute [Authorize]
@using Bethuya.Hybrid.Shared.Services
@using BlazorBlueprint.Components
@using BlazorBlueprint.Primitives
@inject IProfileApi ProfileApi
@inject NavigationManager Navigation

<PageTitle>Diversity &amp; Inclusion Profile — Bethuya</PageTitle>

<section class="profile-page" aria-label="Diversity and inclusion profile">
    <div class="profile-container">
        <header class="profile-header">
            <p class="profile-step">Step 3 of 3 · Optional accessibility and inclusion details</p>
            <h1 class="profile-title">Accessibility &amp; Inclusion</h1>
            <p class="profile-subtitle">Optional. Share only what helps us support you better.</p>
            <p class="profile-consent-note">
                <a href="/" class="skip-link-text" data-test="skip-aide-link">Skip for now</a>
            </p>
            <div class="profile-progress" aria-hidden="true">
                <span class="profile-progress__dot"></span>
                <span class="profile-progress__dot"></span>
                <span class="profile-progress__dot profile-progress__dot--active"></span>
            </div>
        </header>

        <div class="profile-layout">
            <section class="profile-main">
                <EditForm Model="@_model" OnValidSubmit="@HandleValidSubmit" FormName="aide-profile">
                    <DataAnnotationsValidator />

                    <fieldset disabled="@_isLoading">
                        <BbCard Class="profile-form-card">
                            <BbCardHeader>
                                <BbCardTitle>Optional details for better support</BbCardTitle>
                            </BbCardHeader>
                            <BbCardContent Class="profile-form-card__content">
                                @if (_isLoading)
                                {
                                    <div data-test="aide-profile-loading">
                                        <BbAlert Variant="AlertVariant.Info">
                                            <BbAlertDescription>Loading your saved accessibility profile…</BbAlertDescription>
                                        </BbAlert>
                                    </div>
                                }

                                <BbFormSection Title="Accessibility needs">
                                    <div class="space-y-4">
                                        <BbFormFieldSelect @bind-Value="_model.Disability"
                                                           Label="Disability / long-term condition"
                                                           Options="@_disabilityOptions" />

                                        @if (_model.Disability is not "" and not "None" and not "Prefer not to say")
                                        {
                                            <div class="form-group">
                                                <BbLabel For="disability-details">Accessibility requirements or accommodations needed</BbLabel>
                                                <div data-test="disability-details-wrapper">
                                                    <BbTextarea @bind-Value="_model.DisabilityDetails"
                                                                Id="disability-details"
                                                                Placeholder="Tell us what would help you participate fully"
                                                                MaxLength="1000"
                                                                ShowCharacterCount="true"
                                                                Class="w-full" />
                                                </div>
                                            </div>
                                        }

                                        <BbFormFieldInput @bind-Value="_model.DietaryRequirements"
                                                          Label="Dietary requirements"
                                                          Placeholder="e.g. Vegetarian, Vegan, Halal, Gluten-free" />

                                        <BbFormFieldSelect @bind-Value="_model.Neurodiversity"
                                                           Label="Neurodiversity"
                                                           Options="@_neurodiversityOptions" />

                                        <BbFormFieldInput @bind-Value="_model.AdditionalSupport"
                                                          Label="Additional support needs"
                                                          Placeholder="Any additional support you would like us to know" />
                                    </div>
                                </BbFormSection>

                                <BbFormSection Title="Inclusion signal">
                                    <BbFormFieldRadioGroup @bind-Value="_model.UnderrepresentedInTech"
                                                           Label="Do you identify with any group that is underrepresented in tech communities?"
                                                           InputClass="employment-radio-group">
                                        <BbRadioGroupItem Value="@("Yes")" Label="Yes" />
                                        <BbRadioGroupItem Value="@("No")" Label="No" />
                                        <BbRadioGroupItem Value="@("Prefer not to say")" Label="Prefer not to say" />
                                    </BbFormFieldRadioGroup>
                                </BbFormSection>

                                <BbFormSection Title="Languages spoken">
                                    <BbFormFieldInput @bind-Value="_model.LanguageProficiency"
                                                      Label="Languages spoken"
                                                      Placeholder="e.g. English, Hindi, Marathi" />
                                </BbFormSection>

                                @if (_loadErrorMessage is not null)
                                {
                                    <div data-test="aide-load-error">
                                        <BbAlert Variant="AlertVariant.Danger">
                                            <BbAlertDescription>@_loadErrorMessage</BbAlertDescription>
                                        </BbAlert>
                                    </div>
                                }

                                @if (_errorMessage is not null)
                                {
                                    <div data-test="aide-error">
                                        <BbAlert Variant="AlertVariant.Danger">
                                            <BbAlertDescription>@_errorMessage</BbAlertDescription>
                                        </BbAlert>
                                    </div>
                                }
                            </BbCardContent>
                        </BbCard>
                    </fieldset>

                    <div class="profile-actions">
                        <div class="profile-actions-copy">
                            <p class="profile-actions-title">This step is optional.</p>
                            <p class="profile-actions-hint">Save what you want, or skip now.</p>
                        </div>
                        <button type="submit" class="profile-primary-button" disabled="@(_isLoading || _isSaving)" data-test="save-aide-btn">
                            @if (_isSaving)
                            {
                                <span>Saving…</span>
                            }
                            else
                            {
                                <span>Save &amp; Finish</span>
                            }
                        </button>

                        <a href="/" class="skip-link-text" data-test="skip-aide-link-footer">Skip for now</a>
                    </div>
                </EditForm>
            </section>

            <aside class="profile-sidebar" aria-label="How Bethuya handles this information">
                <BbCard Class="profile-info-card">
                    <BbCardHeader>
                        <BbCardTitle>Why we ask:</BbCardTitle>
                    </BbCardHeader>
                    <BbCardContent>
                        <ul class="profile-bullets">
                            <li>To plan accessible events</li>
                            <li>To improve inclusion over time</li>
                        </ul>
                        <p class="profile-actions-hint">Your responses are private and used only in aggregate.</p>
                    </BbCardContent>
                </BbCard>
            </aside>
        </div>
    </div>
</section>

@code {
    private readonly AideProfileModel _model = new();
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _loadErrorMessage;
    private string? _errorMessage;
    private static bool IsSocialBypassEnabled =>
        string.Equals(Environment.GetEnvironmentVariable("Onboarding__BypassSocialConnections"), "true", StringComparison.OrdinalIgnoreCase);
    private static bool IsMandatoryBypassEnabled =>
        string.Equals(Environment.GetEnvironmentVariable("Onboarding__BypassMandatoryProfile"), "true", StringComparison.OrdinalIgnoreCase);
    private static string NormalizeUnderrepresentedSignal(string? value)
        => value switch
        {
            "Yes" => "Yes",
            "No" => "No",
            "Prefer not to say" => "Prefer not to say",
            _ => ""
        };

    private static IReadOnlyList<SelectOption<string>> Opts(params string[] values) =>
        [new SelectOption<string>("", "Prefer not to say"), ..values.Select(v => new SelectOption<string>(v, v))];

    private static readonly IReadOnlyList<SelectOption<string>> _disabilityOptions = Opts(
        "None", "Physical / mobility", "Visual impairment", "Hearing impairment",
        "Cognitive / learning", "Mental health", "Other");

    private static readonly IReadOnlyList<SelectOption<string>> _neurodiversityOptions = Opts(
        "None identified", "ADHD", "Autism spectrum", "Dyslexia", "Other");

    protected override async Task OnInitializedAsync()
    {
        try
        {
            ProfileCompletionStatusDto? status = null;

            try
            {
                status = await ProfileApi.GetCompletionStatusAsync();
            }
            catch
            {
                // If the step-gating lookup fails, still try to hydrate the saved AIDE data.
            }

            if (status is { IsProfileComplete: false } && !IsMandatoryBypassEnabled)
            {
                Navigation.NavigateTo("/registration/mandatory", replace: true);
                return;
            }

            if (status is { IsSocialConnectionsComplete: false } && !IsSocialBypassEnabled)
            {
                Navigation.NavigateTo("/registration/social", replace: true);
                return;
            }

            var profile = await ProfileApi.GetAideProfileAsync();
            ApplySavedProfile(profile);
        }
        catch (Exception)
        {
            _loadErrorMessage = "We couldn't load your saved inclusion profile. Review the form before saving.";
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task HandleValidSubmit()
    {
        _isSaving = true;
        _errorMessage = null;

        try
        {
            static string? N(string s) => string.IsNullOrWhiteSpace(s) ? null : s.Trim();

            await ProfileApi.SaveAideProfileAsync(new SaveAideProfileDto(
                GenderIdentity: null,
                SelfDescribeGender: null,
                AgeRange: null,
                Ethnicity: null,
                SelfDescribeEthnicity: null,
                Disability: N(_model.Disability),
                DisabilityDetails: N(_model.DisabilityDetails),
                DietaryRequirements: N(_model.DietaryRequirements),
                LgbtqIdentity: null,
                ParentalStatus: null,
                Religion: null,
                Caste: null,
                Neighborhood: null,
                ModeOfTransportation: null,
                SocioeconomicBackground: null,
                Neurodiversity: N(_model.Neurodiversity),
                CaregivingResponsibilities: null,
                LanguageProficiency: N(_model.LanguageProficiency),
                EducationalBackground: null,
                HowDidYouHear: N(NormalizeUnderrepresentedSignal(_model.UnderrepresentedInTech)),
                AdditionalSupport: N(_model.AdditionalSupport)));

            Navigation.NavigateTo("/");
        }
        catch (Exception)
        {
            _errorMessage = "Failed to save your profile. Please try again.";
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void ApplySavedProfile(AideProfileDto? profile)
    {
        if (profile is null)
        {
            return;
        }

        _model.Disability = profile.Disability ?? "";
        _model.DisabilityDetails = profile.DisabilityDetails ?? "";
        _model.DietaryRequirements = profile.DietaryRequirements ?? "";
        _model.Neurodiversity = profile.Neurodiversity ?? "";
        _model.LanguageProficiency = profile.LanguageProficiency ?? "";
        _model.AdditionalSupport = profile.AdditionalSupport ?? "";
        _model.UnderrepresentedInTech = NormalizeUnderrepresentedSignal(profile.HowDidYouHear);
    }

    private sealed class AideProfileModel
    {
        public string Disability { get; set; } = "";
        public string DisabilityDetails { get; set; } = "";
        public string DietaryRequirements { get; set; } = "";
        public string Neurodiversity { get; set; } = "";
        public string UnderrepresentedInTech { get; set; } = "";
        public string LanguageProficiency { get; set; } = "";
        public string AdditionalSupport { get; set; } = "";
    }
}
