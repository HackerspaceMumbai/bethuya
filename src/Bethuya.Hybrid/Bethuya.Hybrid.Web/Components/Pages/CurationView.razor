    private IReadOnlyList<CurationRegistrantDto> RankForSuggestion(IReadOnlyList<CurationRegistrantDto> registrants)
        => registrants
            .OrderByDescending(ScoreSuggestionCandidate)
            .ThenByDescending(registrant => registrant.RegisteredAt)
            .ToList();

    private double ScoreSuggestionCandidate(CurationRegistrantDto registrant)
    {
        var fairnessGain = registrant.Impact.DeltaPercentByDimension.Values.Where(value => value > 0).Sum() * 100;
        var fairnessRisk = Math.Abs(registrant.Impact.DeltaPercentByDimension.Values.Where(value => value < 0).Sum()) * 100;
        var intentBoost = registrant.Intent.Evidence switch
        {
            "High" => 12,
            "Medium" => 6,
            _ => 1
        };
        var reliabilityBoost = !registrant.Reliability.HasHistory
            ? 3
            : registrant.Reliability.Score / 8.0;
        var discoveryBoost = registrant.Profile.IsFirstTimer ? 4 : 0;
        var orgPenalty = registrant.Impact.DeltaPercentByDimension
            .Where(delta => DimensionKeyMatches(delta.Key, "org"))
            .Select(delta => delta.Value)
            .FirstOrDefault() < -0.0001
            ? 4
            : 0;

        var baseScore = fairnessGain - fairnessRisk + intentBoost + reliabilityBoost + discoveryBoost - orgPenalty;

        return _cohortStrategy switch
        {
            "Fairness-first" => baseScore + fairnessGain * 0.8 - fairnessRisk * 0.2,
            "Reliability-first" => baseScore + reliabilityBoost * 2.3 - fairnessRisk * 0.15,
            "Discovery mode" => baseScore + discoveryBoost * 2.5 - reliabilityBoost * 0.2,
            _ => baseScore
        };
    }

    private IReadOnlyList<CurationRegistrantDto> SelectSuggestedCohort(IReadOnlyList<CurationRegistrantDto> ranked, int targetSize)
    {
        var selected = new List<CurationRegistrantDto>(targetSize);

        foreach (var registrant in ranked)
        {
            if (selected.Count >= targetSize)
            {
                break;
            }

            if (_avoidLowReliability && IsLowReliability(registrant))
            {
                continue;
            }

            if (_limitOrgConcentration && WouldExceedOrgConcentration(selected, registrant))
            {
                continue;
            }

            selected.Add(registrant);
        }

        if (selected.Count < targetSize)
        {
            foreach (var registrant in ranked.Where(candidate => selected.All(existing => existing.RegistrationId != candidate.RegistrationId)))
            {
                if (selected.Count >= targetSize)
                {
                    break;
                }

                selected.Add(registrant);
            }
        }

        if (_enforceFirstTimerShare)
        {
            EnsureFirstTimerTarget(selected, ranked, targetSize);
        }

        return selected.Take(targetSize).ToList();
    }

    private static bool IsLowReliability(CurationRegistrantDto registrant)
        => registrant.Reliability.HasHistory && registrant.Reliability.Score < 60;

    private bool WouldExceedOrgConcentration(IReadOnlyCollection<CurationRegistrantDto> selected, CurationRegistrantDto candidate)
    {
        if (string.IsNullOrWhiteSpace(candidate.Profile.Organization) || selected.Count < 2)
        {
            return false;
        }

        var orgCount = selected.Count(existing =>
            string.Equals(existing.Profile.Organization, candidate.Profile.Organization, StringComparison.OrdinalIgnoreCase));
        var projectedShare = (double)(orgCount + 1) / (selected.Count + 1);

        return projectedShare > MaxOrgConcentrationLimit;
    }

    private void EnsureFirstTimerTarget(List<CurationRegistrantDto> selected, IReadOnlyList<CurationRegistrantDto> ranked, int targetSize)
    {
        var requiredFirstTimers = (int)Math.Ceiling(targetSize * Math.Clamp(_firstTimerTargetPercent / 100d, 0, 1));
        var currentFirstTimers = selected.Count(registrant => registrant.Profile.IsFirstTimer);
        if (currentFirstTimers >= requiredFirstTimers)
        {
            return;
        }

        var replacementPool = selected
            .Where(registrant => !registrant.Profile.IsFirstTimer)
            .OrderBy(ScoreSuggestionCandidate)
            .ToList();
        var firstTimerCandidates = ranked
            .Where(registrant => registrant.Profile.IsFirstTimer && selected.All(existing => existing.RegistrationId != registrant.RegistrationId))
            .ToList();

        foreach (var replacement in replacementPool)
        {
            if (currentFirstTimers >= requiredFirstTimers || firstTimerCandidates.Count == 0)
            {
                break;
            }

            var candidate = firstTimerCandidates[0];
            firstTimerCandidates.RemoveAt(0);

            var replaceIndex = selected.FindIndex(existing => existing.RegistrationId == replacement.RegistrationId);
            if (replaceIndex < 0)
            {
                continue;
            }

            selected[replaceIndex] = candidate;
            currentFirstTimers++;
        }
    }

    private SuggestionEntry CreateSuggestionEntry(CurationRegistrantDto registrant, bool isManual)
    {
        var fairnessContribution = registrant.Impact.DeltaPercentByDimension
            .Where(delta => delta.Value > 0.0001)
            .OrderByDescending(delta => delta.Value)
            .Take(2)
            .Select(delta => $"{ToDimensionLabel(delta.Key)} {ToDeltaPercent(delta.Value)}")
            .ToList();
        var fairnessSummary = fairnessContribution.Count == 0
            ? "Balanced impact with no clear fairness lift"
            : string.Join(", ", fairnessContribution);

        var intentStrength = registrant.Intent.Evidence switch
        {
            "High" => "High evidence and authentic signal",
            "Medium" => "Moderate evidence, verify intent details",
            _ => "Weak evidence signal, review authenticity"
        };

        var orgDiversity = registrant.Impact.DeltaPercentByDimension
            .FirstOrDefault(delta => DimensionKeyMatches(delta.Key, "org"))
            .Value switch
            {
                > 0.0001 => "Improves organization mix",
                < -0.0001 => "May concentrate organization representation",
                _ => "Neutral org-mix effect"
            };

        var reliability = !registrant.Reliability.HasHistory
            ? "No history — validate with intent and impact"
            : registrant.Reliability.Score >= ReliabilityTarget
                ? $"Reliable attendance signal ({registrant.Reliability.Score}%)"
                : $"Moderate attendance reliability ({registrant.Reliability.Score}%)";

        return new SuggestionEntry(isManual, fairnessSummary, intentStrength, orgDiversity, reliability);
    }

    private bool HasMeaningfulProposalOpportunity
    {
        get
        {
            if (_dashboard is null)
            {
                return false;
            }

            if (_dashboard.CurationInsights.Count > 0)
            {
                return true;
            }

            if (_dashboard.Dimensions.Any(d => !d.IsSuppressed))
            {
                return true;
            }

            return _dashboard.Registrants.Any(r =>
                !r.Impact.IsSuppressed &&
                r.Impact.DeltaPercentByDimension.Values.Any(value => Math.Abs(value) > 0.0001));
        }
    }


