            "inclusion" => "socioeconomic",
            "underrep" or "underrepresented" or "underrepresentation" => "socioeconomic",
            _ => normalized
        };
    }

    private IReadOnlyList<BudgetChip> ApplyImpactHighlights(IReadOnlyList<BudgetChip> chips)
    {
        if (!HasActiveProjection)
        {
            return chips.Select(chip => chip with { IsHighlighted = false, ShowDelta = false }).ToList();
        }

        if (chips.Count == 0)
        {
            return chips;
        }

        var highlightedLabels = new HashSet<string>(StringComparer.Ordinal);
        var strongestPositive = chips
            .Where(chip => chip.SignedDelta > 0.0001)
            .OrderByDescending(chip => chip.SignedDelta)
            .FirstOrDefault();
        var strongestNegative = chips
            .Where(chip => chip.SignedDelta < -0.0001)
            .OrderBy(chip => chip.SignedDelta)
            .FirstOrDefault();

        if (strongestPositive is not null)
        {
            highlightedLabels.Add(strongestPositive.Label);
        }

        if (strongestNegative is not null)
        {
            highlightedLabels.Add(strongestNegative.Label);
        }

        if (highlightedLabels.Count == 0)
        {
            var fallback = chips
                .Where(chip => Math.Abs(chip.SignedDelta) > 0.0001)
                .OrderByDescending(chip => Math.Abs(chip.SignedDelta))
                .FirstOrDefault();

            if (fallback is not null)
            {
                highlightedLabels.Add(fallback.Label);
            }
        }

        return chips
            .Select(chip => chip with
            {
                IsHighlighted = highlightedLabels.Contains(chip.Label),
                ShowDelta = highlightedLabels.Contains(chip.Label) && chip.Delta is not null
            })
            .OrderBy(chip => BudgetChipOrder(chip.Label))
            .ToList();
    }

