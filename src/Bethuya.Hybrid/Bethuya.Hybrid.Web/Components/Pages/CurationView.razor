    private static Microsoft.AspNetCore.Components.MarkupString RenderHighlightedAnswer(string answer, IReadOnlyList<string> signals)
        => new(BuildHighlightedAnswerMarkup(answer, signals));

    private static string BuildHighlightedAnswerMarkup(string answer, IReadOnlyList<string> signals)
    {
        var terms = BuildAnswerHighlightTerms(answer, signals);
        if (terms.Count == 0)
        {
            return System.Net.WebUtility.HtmlEncode(answer);
        }

        var pattern = string.Join("|", terms.OrderByDescending(term => term.Length).Select(System.Text.RegularExpressions.Regex.Escape));
        var regex = new System.Text.RegularExpressions.Regex(
            $@"\b({pattern})\b",
            System.Text.RegularExpressions.RegexOptions.IgnoreCase | System.Text.RegularExpressions.RegexOptions.CultureInvariant);

        var markup = new System.Text.StringBuilder();
        var lastIndex = 0;

        foreach (System.Text.RegularExpressions.Match match in regex.Matches(answer))
        {
            if (match.Index > lastIndex)
            {
                markup.Append(System.Net.WebUtility.HtmlEncode(answer[lastIndex..match.Index]));
            }

            markup.Append("<span class=\"answer-highlight\">");
            markup.Append(System.Net.WebUtility.HtmlEncode(match.Value));
            markup.Append("</span>");
            lastIndex = match.Index + match.Length;
        }

        if (lastIndex < answer.Length)
        {
            markup.Append(System.Net.WebUtility.HtmlEncode(answer[lastIndex..]));
        }

        return markup.ToString();
    }

    private static IReadOnlyList<string> BuildAnswerHighlightTerms(string answer, IReadOnlyList<string> signals)
    {
        var terms = new List<string>();

        void AddTerm(string term)
        {
            if (!string.IsNullOrWhiteSpace(term)
                && answer.Contains(term, StringComparison.OrdinalIgnoreCase)
                && !terms.Any(existing => existing.Equals(term, StringComparison.OrdinalIgnoreCase)))
            {
                terms.Add(term);
            }
        }

        foreach (var signal in signals)
        {
            if (signal.Contains("builder", StringComparison.OrdinalIgnoreCase))
            {
                AddTerm("build");
                AddTerm("building");
                AddTerm("project");
                AddTerm("projects");
                AddTerm("prototype");
            }

            if (signal.Contains("community", StringComparison.OrdinalIgnoreCase))
            {
                AddTerm("community");
                AddTerm("collaborate");
                AddTerm("collaboration");
                AddTerm("network");
                AddTerm("networking");
                AddTerm("meet");
            }

            if (signal.Contains("fairness", StringComparison.OrdinalIgnoreCase))
            {
                AddTerm("fairness");
                AddTerm("inclusion");
                AddTerm("equity");
            }
        }

        foreach (var term in new[]
                 {
                     "AI",
                     "research",
                     "build",
                     "building",
                     "project",
                     "projects",
                     "tools",
                     "tool",
                     "community",
                     "collaborate",
                     "collaboration",
                     "network",
                     "networking",
                     "learn",
                     "mentor",
                     "mentoring",
                     "accessibility",
                     "inclusion",
                     "equity",
                     "open source",
                     "hardware",
                     "design",
                     "IoT"
                 })
        {
            if (terms.Count >= 3)
            {
                break;
            }

            AddTerm(term);
        }

        return terms;
    }

