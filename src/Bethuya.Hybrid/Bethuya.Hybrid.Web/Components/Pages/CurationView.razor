    private static IReadOnlyList<string> GetQueueSignalTags(CurationRegistrantDto registrant)
    {
        var tags = new List<(string Label, int Priority)>();
        var hasStandout = registrant.Profile.HasOrganizerStandoutContribution;

        // 1) impact signals
        if (hasStandout)
        {
            tags.Add(("⭐ Standout", 1));
        }
        else if (registrant.Recommendation.Tone == "positive")
        {
            tags.Add((registrant.Profile.IsFirstTimer ? "⭐ Strong new" : "⭐ High impact", 1));
        }

        // 2) intent signals
        if (registrant.Intent.Evidence == "Low")
        {
            tags.Add(("Low intent", 2));
        }
        else if (registrant.Intent.Evidence == "High")
        {
            tags.Add(("High intent", 2));
        }

        // 3) fairness signals
        var fairnessSignals = new List<string>();

        if (HasPositiveImpactIn(registrant, "org"))
        {
            fairnessSignals.Add("🌱 New Org");
        }

        if (HasPositiveImpactIn(registrant, "language"))
        {
            fairnessSignals.Add("+ Lang boost");
        }

        if (HasPositiveImpactIn(registrant, "geo"))
        {
            fairnessSignals.Add("+ Geo boost");
        }

        if (HasPositiveImpactIn(registrant, "education"))
        {
            fairnessSignals.Add("+ Edu boost");
        }

        if (HasPositiveImpactIn(registrant, "socioeconomic"))
        {
            fairnessSignals.Add("+ Inclusion boost");
        }

        tags.AddRange(fairnessSignals.Select(signal => (signal, 3)));

        if (tags.Count == 0)
        {
            tags.Add((registrant.Profile.IsFirstTimer ? "🆕 New voice" : "Balanced", 1));
        }

        if (tags.Count <= 2)
        {
            return tags.Select(tag => tag.Label).ToList();
        }

        var visible = tags.Take(2).Select(tag => tag.Label).ToList();
        visible.Add($"+{tags.Count - 2}");
        return visible;
    }

