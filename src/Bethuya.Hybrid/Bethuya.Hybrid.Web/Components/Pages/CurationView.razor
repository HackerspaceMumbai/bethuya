    private IReadOnlyList<ImpactMetricRow> BuildImpactFairnessRows()
        =>
        [
            BuildImpactMetricRow("Gender", GetImpactProjectionDelta("gender")),
            BuildImpactMetricRow("Geography", GetImpactProjectionDelta("geo")),
            BuildImpactMetricRow("Language", GetImpactProjectionDelta("language")),
            BuildImpactMetricRow("Education", GetImpactProjectionDelta("education")),
            BuildImpactMetricRow("Inclusion", GetImpactProjectionDelta("socioeconomic")),
            BuildImpactMetricRow("First Timer", ImpactProjectedFirstTimerShare - CurrentFirstTimerShare),
            BuildImpactMetricRow("Equity", ImpactProjectedUnderrepShare - CurrentUnderrepShare)
        ];

    private IReadOnlyList<ImpactMetricGroup> BuildImpactFairnessGroups()
    {
        var rows = BuildImpactFairnessRows();
        var improvements = rows.Where(row => row.State.Equals("positive", StringComparison.Ordinal)).ToArray();
        var risks = rows
            .Where(row => row.State.Equals("warning", StringComparison.Ordinal))
            .OrderByDescending(row => Math.Abs(ParsePercent(row.Value)))
            .ToArray();
        var neutral = rows.Where(row => row.State.Equals("neutral", StringComparison.Ordinal)).ToArray();

        return
        [
            new ImpactMetricGroup("improvements", "IMPROVEMENTS", "positive", "+ ", ShowDelta: true, Rows: improvements, EmptySummary: "No meaningful uplift"),
            new ImpactMetricGroup("risks", "RISKS", "warning", "- ", ShowDelta: true, Rows: risks, EmptySummary: "No meaningful risk"),
            new ImpactMetricGroup("neutral", "NEUTRAL", "neutral", "~ ", ShowDelta: false, Rows: neutral, EmptySummary: "~ None")
        ];
    }

    private static ImpactMetricRow BuildImpactMetricRow(string label, double delta)
    {
        var state = Math.Abs(delta) < MaterialImpactDeltaThreshold ? "neutral" : delta > 0 ? "positive" : "warning";
