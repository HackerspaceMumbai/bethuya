    private int GetReliabilityPercentile(CurationRegistrantDto registrant)
    {
        if (_dashboard is null || !registrant.Reliability.HasHistory)
        {
            return 0;
        }

        var scores = _dashboard.Registrants
            .Where(r => r.Reliability.HasHistory)
            .Select(r => r.Reliability.Score)
            .ToList();

        if (scores.Count == 0)
        {
            return 0;
        }

        var scoresAtOrBelow = scores.Count(score => score <= registrant.Reliability.Score);
        return (int)Math.Round((scoresAtOrBelow * 100d) / scores.Count, MidpointRounding.AwayFromZero);
    }

    private static string GetOrdinalSuffix(int value)
    {
        var abs = Math.Abs(value);
        var tens = abs % 100;
        if (tens is 11 or 12 or 13)
        {
            return "th";
        }

        return (abs % 10) switch
        {
            1 => "st",
            2 => "nd",
            3 => "rd",
            _ => "th"
        };
    }

