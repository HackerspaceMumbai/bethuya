    private static double GetBalancedScore(CurationRegistrantDto registrant)
    {
        var baseScore = SumPositiveImpact(registrant.Impact) * 100;
        baseScore += registrant.Profile.IsFirstTimer ? 4 : 0;
        baseScore += registrant.Intent.Evidence switch
        {
            "High" => 4,
            "Medium" => 2,
            _ => 0
        };
        baseScore += registrant.Reliability.HasHistory ? registrant.Reliability.Score / 25.0 : 1;
        return baseScore;
    }

