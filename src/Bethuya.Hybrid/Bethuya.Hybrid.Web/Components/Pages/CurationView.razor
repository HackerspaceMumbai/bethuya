    private static double SumPositiveImpact(ImpactPreviewDto impact)
        => impact.DeltaPercentByDimension.Values.Where(value => value > 0).Sum();

    private static double GetBalancedScore(CurationRegistrantDto registrant)
    {
        var baseScore = SumPositiveImpact(registrant.Impact) * 100;
        baseScore += registrant.Profile.IsFirstTimer ? 4 : 0;
        baseScore += registrant.Intent.Evidence switch
        {
            "High" => 4,
            "Medium" => 2,
            _ => 0
        };
        baseScore += registrant.Reliability.HasHistory ? registrant.Reliability.Score / 25.0 : 1;
        return baseScore;
    }

    private bool HasMeaningfulProposalOpportunity
    {
        get
        {
            if (_dashboard is null)
            {
                return false;
            }

            if (_dashboard.CurationInsights.Count > 0)
            {
                return true;
            }

            if (_dashboard.Dimensions.Any(d => !d.IsSuppressed))
            {
                return true;
            }

            return _dashboard.Registrants.Any(r =>
                !r.Impact.IsSuppressed &&
                r.Impact.DeltaPercentByDimension.Values.Any(value => Math.Abs(value) > 0.0001));
        }
    }

