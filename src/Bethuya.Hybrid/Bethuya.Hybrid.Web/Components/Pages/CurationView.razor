    private static ImpactMetricRow BuildImpactMetricRow(string label, double delta)
    {
        var state = Math.Abs(delta) <= 0.0001 ? "neutral" : delta > 0 ? "positive" : "warning";
        return new ImpactMetricRow(label, ToDeltaPercent(delta), state);
    }

    private static double GetTopOrganizationConcentration(IReadOnlyList<CurationRegistrantDto> cohort)
    {
        if (cohort.Count == 0)
        {
            return 0;
        }

        var highestOrganizationCount = cohort
            .Select(registrant => registrant.Profile.Organization)
            .Where(organization => !string.IsNullOrWhiteSpace(organization))
            .GroupBy(organization => organization, StringComparer.OrdinalIgnoreCase)
            .Select(group => group.Count())
            .DefaultIfEmpty(0)
            .Max();

        return Ratio(highestOrganizationCount, cohort.Count);
    }

