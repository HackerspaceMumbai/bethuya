#!/usr/bin/env bash

set -euo pipefail

readonly REPO_ROOT="$(git rev-parse --show-toplevel)"
readonly CONFIG_PATH="${REPO_ROOT}/.security/gitleaks.toml"
readonly GITLEAKS_ALLOWLIST_PATH="${REPO_ROOT}/.gitleaksallowlist"
readonly SUGGESTED_FIX='Move secret values to Azure Key Vault (or azd env) and reference them by name.'

mapfile -t STAGED_FILES < <(git diff --cached --name-only --diff-filter=ACMR)

if [[ "${#STAGED_FILES[@]}" -eq 0 ]]; then
    exit 0
fi

if ! command -v gitleaks >/dev/null 2>&1; then
    echo "❌ Secret leak checks failed: gitleaks is not installed."
    echo "   Suggested fix: install gitleaks, then run scripts/setup-dev-security.sh or scripts/setup-dev-security.ps1."
    exit 1
fi

if [[ ! -f "${CONFIG_PATH}" ]]; then
    echo "❌ Secret leak checks failed: missing ${CONFIG_PATH}."
    exit 1
fi

errors=()

is_allowlisted_azure_file() {
    local file_path="$1"
    case "${file_path}" in
        .azure/config.json|.azure/config.yaml|.azure/config.yml|.azure/README.md)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

for staged_file in "${STAGED_FILES[@]}"; do
    if [[ "${staged_file}" == .azure/* ]] && ! is_allowlisted_azure_file "${staged_file}"; then
        errors+=("${staged_file}|1|Tracking files under .azure/ is blocked by policy.|Keep only approved non-sensitive config files under .azure/.")
    fi

    if [[ "${staged_file}" == *.json ]]; then
        staged_json="$(git show ":${staged_file}" 2>/dev/null || true)"
        if [[ -n "${staged_json}" ]] && printf '%s\n' "${staged_json}" | grep -Eiq '"SecretUri"[[:space:]]*:[[:space:]]*"[^"]+"'; then
            if printf '%s\n' "${staged_json}" | grep -Eiq '"SecretValue"[[:space:]]*:[[:space:]]*"[^"]+"'; then
                line_number="$(printf '%s\n' "${staged_json}" | grep -Ein '"Secret(Uri|Value)"[[:space:]]*:[[:space:]]*"[^"]+"' | head -n1 | cut -d: -f1)"
                errors+=("${staged_file}|${line_number:-1}|Detected Azure Key Vault export schema fields (SecretUri/SecretValue).|Never commit Key Vault exports. Replace with secret references.")
            fi
        fi

        if [[ -n "${staged_json}" ]] && printf '%s\n' "${staged_json}" | grep -Eiq '"parameters"[[:space:]]*:'; then
            if printf '%s\n' "${staged_json}" | grep -Eiq '"value"[[:space:]]*:[[:space:]]*"[^"]+"'; then
                line_number="$(printf '%s\n' "${staged_json}" | grep -Ein '"value"[[:space:]]*:[[:space:]]*"[^"]+"' | head -n1 | cut -d: -f1)"
                errors+=("${staged_file}|${line_number:-1}|Detected literal parameter value in JSON parameters object.|Use Key Vault references or secure runtime configuration, not inline values.")
            fi
        fi
    fi

    if [[ "${staged_file}" == *.bicep || "${staged_file}" == *.bicepparam ]]; then
        staged_bicep="$(git show ":${staged_file}" 2>/dev/null || true)"
        if [[ -n "${staged_bicep}" ]] && printf '%s\n' "${staged_bicep}" | grep -Eq '^[[:space:]]*(@secure\(\)[[:space:]]*)?param[[:space:]]+[A-Za-z_][A-Za-z0-9_]*[[:space:]]+string[[:space:]]*=[[:space:]]*'\''[^'\'']+'\''' ; then
            line_number="$(printf '%s\n' "${staged_bicep}" | grep -En '^[[:space:]]*(@secure\(\)[[:space:]]*)?param[[:space:]]+[A-Za-z_][A-Za-z0-9_]*[[:space:]]+string[[:space:]]*=[[:space:]]*'\''[^'\'']+'\''' | head -n1 | cut -d: -f1)"
            errors+=("${staged_file}|${line_number:-1}|Detected Bicep parameter default assignment for a string literal.|Declare the param without a literal default and source value from Key Vault or deployment inputs.")
        fi
    fi
done

report_file="$(mktemp "${TMPDIR:-/tmp}/gitleaks-pre-commit.XXXXXX.json")"

gitleaks_exit_code=0
if ! gitleaks protect --staged --redact --config "${CONFIG_PATH}" --gitleaks-ignore-path "${GITLEAKS_ALLOWLIST_PATH}" --report-format json --report-path "${report_file}" >/dev/null 2>&1; then
    gitleaks_exit_code=$?
fi

if [[ ${gitleaks_exit_code} -ne 0 ]] && [[ -s "${report_file}" ]]; then
    python_bin="$(command -v python3 || command -v python || true)"
    if [[ -n "${python_bin}" ]]; then
        while IFS='|' read -r file_path line_number reason fix; do
            errors+=("${file_path}|${line_number}|${reason}|${fix}")
        done < <("${python_bin}" -c '
import json
import sys
from pathlib import Path

report_path = Path(sys.argv[1])
default_fix = sys.argv[2]

try:
    findings = json.loads(report_path.read_text(encoding="utf-8"))
except Exception:
    findings = []

for finding in findings:
    file_path = finding.get("File") or finding.get("file") or "unknown-file"
    line_number = finding.get("StartLine") or finding.get("startLine") or 1
    rule_id = finding.get("RuleID") or finding.get("RuleId") or "gitleaks-rule"
    description = finding.get("Description") or finding.get("description") or "Secret-like content detected by Gitleaks."
    print(f"{file_path}|{line_number}|{rule_id}: {description}|{default_fix}")
' "${report_file}" "${SUGGESTED_FIX}")
    else
        errors+=("unknown-file|1|Gitleaks reported findings but Python is unavailable to format details.|Install Python to format findings, then re-run commit.")
    fi
elif [[ ${gitleaks_exit_code} -ne 0 ]]; then
    errors+=("unknown-file|1|Gitleaks scan did not complete successfully.|Run gitleaks manually to inspect the failure and fix scanner setup.")
fi

rm -f "${report_file}"

if [[ "${#errors[@]}" -gt 0 ]]; then
    echo "❌ Commit blocked by Bethuya secret leak prevention checks."
    for issue in "${errors[@]}"; do
        IFS='|' read -r file_path line_number reason fix <<< "${issue}"
        echo "  - File: ${file_path}"
        echo "    Line: ${line_number}"
        echo "    Reason: ${reason}"
        echo "    Suggested Fix: ${fix}"
    done
    exit 1
fi

echo "✅ Secret leak checks passed."
