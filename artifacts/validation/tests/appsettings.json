{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // "*" allows Azure Container Apps reverse proxy to route traffic.
  // Host header validation at the network level is handled by Container Apps ingress rules.
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Authentication": {
    "Provider": "None",
    "Entra": {
      "Instance": "https://login.microsoftonline.com/",
      "TenantId": "",
      "ClientId": "",
      "ClientSecret": "",
      "Domain": "",
      "CallbackPath": "/signin-oidc"
    },
    "Auth0": {
      "Domain": "",
      "ClientId": "",
      "ClientSecret": "",
      "Audience": "",
      "CallbackPath": "/callback"
    },
    "Keycloak": {
      "Authority": "",
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/signin-oidc"
    }
  },
  "SocialConnections": {
    "GitHub": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/oauth/github/callback",
      "Scopes": [ "read:user" ]
    },
    "LinkedIn": {
      "ClientId": "",
      "ClientSecret": "",
      "CallbackPath": "/oauth/linkedin/callback",
      "Scopes": [ "openid", "profile" ]
    }
  }
}
